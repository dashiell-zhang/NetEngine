@page "/operations/queuetasksetting"
@using Application.Model.TaskCenter
@attribute [ReuseTabsPageTitle("队列任务配置")]

<div class="queue-task-page">
    <div class="queue-task-page__hero">
        <div>
            <div class="queue-task-page__eyebrow">Operations</div>
            <h2 class="queue-task-page__title">队列任务配置台</h2>
            <div class="queue-task-page__subtitle">集中维护 QueueTask 分类任务的启停状态、并发额度与备注说明，让队列消费能力调整和日常运维管理都在一个视图内完成</div>

            <div class="queue-task-page__hero-tools">
                <Button Class="queue-task-page__hero-button queue-task-page__hero-button--light" Icon="reload" OnClick="GetTaskSettingListAsync">刷新列表</Button>
            </div>
        </div>

        <div class="queue-task-page__stats">
            <div class="queue-task-page__stat-card">
                <span class="queue-task-page__stat-label">任务总量</span>
                <strong class="queue-task-page__stat-value">@pageList.Total</strong>
                <span class="queue-task-page__stat-foot">当前页展示 @(pageList.List?.Count ?? 0) 条配置</span>
            </div>

            <div class="queue-task-page__stat-card">
                <span class="queue-task-page__stat-label">当前页启用</span>
                <strong class="queue-task-page__stat-value">@(pageList.List?.Count(t => t.IsEnable) ?? 0)</strong>
                <span class="queue-task-page__stat-foot">便于快速观察当前页投产中的任务数量</span>
            </div>

            <div class="queue-task-page__stat-card">
                <span class="queue-task-page__stat-label">分页状态</span>
                <strong class="queue-task-page__stat-value queue-task-page__stat-value--small">第 @(page) 页 / 每页 @pageSize 条</strong>
                <span class="queue-task-page__stat-foot">当前分类固定为 QueueTask</span>
            </div>
        </div>
    </div>

    <Card Class="queue-task-page__card queue-task-page__card--compact" BodyStyle="padding: 14px 14px 10px">
        <div class="queue-task-page__list-shell">
            <div class="queue-task-page__table-wrap">
                <Table TItem="TaskSettingDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

                    <ColumnDefinitions>
                        <ActionColumn Title="任务">
                            <div class="queue-task-page__name-cell">
                                <div class="queue-task-page__name-title">@context.Name</div>
                            </div>
                        </ActionColumn>

                        <ActionColumn Title="状态">
                            <Tag Class="queue-task-page__status-tag" Color="@(context.IsEnable ? "#16a34a" : "#94a3b8")">@(context.IsEnable ? "启用中" : "已停用")</Tag>
                        </ActionColumn>

                        <ActionColumn Title="并发">
                            <div class="queue-task-page__semaphore-pill">@context.Semaphore</div>
                        </ActionColumn>

                        <ActionColumn Title="备注">
                            <div class="queue-task-page__remark-cell">@(string.IsNullOrWhiteSpace(context.Remark) ? "暂无备注说明" : context.Remark)</div>
                        </ActionColumn>

                        <PropertyColumn Property="c => (c.UpdateTime ?? c.CreateTime).LocalDateTime" Format="yyyy-MM-dd HH:mm" Title="更新时间"></PropertyColumn>

                        <ActionColumn Title="操作">
                            <Space>
                                <SpaceItem>
                                    <a class="queue-task-page__link" @onclick="() => EditTaskSettingAsync(context)">编辑</a>
                                </SpaceItem>
                            </Space>
                        </ActionColumn>
                    </ColumnDefinitions>

                    <PaginationTemplate>
                        <div class="queue-task-page__pagination">
                            <Pagination Total="@pageList.Total" PageSize="pageSize" Current="page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
                        </div>
                    </PaginationTemplate>

                </Table>
            </div>
        </div>
    </Card>
</div>


<Drawer Closable="true" Width="620" Visible="isShowEditTaskSetting" Title='("任务配置")' OnClose="() => isShowEditTaskSetting = false">
    <Template style="height:100%">
        <div class="queue-task-drawer">
            <Form Class="queue-task-drawer__form" Model="@editTaskSetting" Layout="@FormLayout.Vertical" OnFinish="SaveTaskSettingAsync">
                <div class="queue-task-drawer__section">
                    <div class="queue-task-drawer__section-head">
                        <div>
                            <div class="queue-task-drawer__section-title">基础配置</div>
                        </div>

                        <div class="queue-task-drawer__switch-box">
                            <span class="queue-task-drawer__switch-label">是否启用</span>
                            <Switch @bind-Value="@editTaskSetting.IsEnable" CheckedChildren="是" UnCheckedChildren="否" />
                        </div>
                    </div>

                    <div class="queue-task-drawer__meta-grid">
                        <div class="queue-task-drawer__meta-item">
                            <span class="queue-task-drawer__meta-label">任务名称</span>
                            <span class="queue-task-drawer__meta-value">@(string.IsNullOrWhiteSpace(taskName) ? "-" : taskName)</span>
                        </div>

                        <div class="queue-task-drawer__meta-item">
                            <span class="queue-task-drawer__meta-label">任务类型</span>
                            <span class="queue-task-drawer__meta-value">@(string.IsNullOrWhiteSpace(taskCategory) ? "-" : taskCategory)</span>
                        </div>
                    </div>

                    <FormItem Class="queue-task-drawer__field-item">
                        <div class="queue-task-drawer__field-label">并发</div>
                        <Input Placeholder="QueueTask 并发值" Type="InputType.Number" min="1" @bind-Value="@editTaskSetting.Semaphore" />
                        <div class="queue-task-drawer__field-help">建议结合消费者实例数和单任务耗时设置并发额度，避免任务堆积或竞争过载</div>
                    </FormItem>

                    <FormItem Class="queue-task-drawer__field-item">
                        <div class="queue-task-drawer__field-label">备注</div>
                        <TextArea Placeholder="请输入备注" @bind-Value="@editTaskSetting.Remark" MinRows="4" MaxRows="8" style="width:100%" />
                    </FormItem>
                </div>

                <div class="queue-task-drawer__footer">
                    <Button Class="queue-task-page__action-button queue-task-page__action-button--primary" Type="@ButtonType.Primary" HtmlType="submit" Loading="@saveLoading">保存</Button>
                    <Button Class="queue-task-page__action-button queue-task-page__action-button--default" Type="@ButtonType.Default" @onclick="() => isShowEditTaskSetting = false">取消</Button>
                </div>
            </Form>
        </div>
    </Template>
</Drawer>

