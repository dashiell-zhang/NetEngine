@page "/operations/llmmodel"
@using Application.Model.LLM.LlmModel
@using System.Net.Http.Json
@attribute [ReuseTabsPageTitle("LLM模型管理")]

<div style="margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
    <div>
        <Button Icon="plus" Type="@ButtonType.Primary" @onclick="() => EditLlmModel()">添加</Button>
    </div>

    <div style="margin-left:auto">
        <Form Model="@request" Layout="@FormLayout.Inline" OnFinish="HandleSearchAsync">
            <FormItem>
                <Input @bind-Value="@context.Keyword" Placeholder="名称/模型标识/备注 模糊检索" Style="width: 320px" AllowClear />
            </FormItem>
            <FormItem>
                <Select TItem="bool?" TItemValue="bool?" @bind-Value="@context.IsEnable" Placeholder="是否启用" Style="width: 140px" AllowClear>
                    <SelectOption Value="@((bool?)true)" Label="启用"></SelectOption>
                    <SelectOption Value="@((bool?)false)" Label="停用"></SelectOption>
                </Select>
            </FormItem>
            <FormItem>
                <Space>
                    <Button Type="@ButtonType.Primary" HtmlType="submit">搜索</Button>
                </Space>
            </FormItem>
            <FormItem>
                <Space>
                    <Button OnClick="HandleReset">重置</Button>
                </Space>
            </FormItem>
        </Form>
    </div>
</div>

<Divider Style="margin: 12px 0" />

<Table TItem="LlmModelDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

    <ColumnDefinitions>
        <PropertyColumn Property="c => c.Name" Title="名称"></PropertyColumn>
        <PropertyColumn Property="c => c.ModelId" Title="模型标识"></PropertyColumn>
        <PropertyColumn Property="c => c.Endpoint" Title="端点地址"></PropertyColumn>
        <PropertyColumn Property="c => ProtocolTypeText(c.ProtocolType)" Title="协议类型"></PropertyColumn>
        <PropertyColumn Property="c => c.IsEnable" Title="启用"></PropertyColumn>
        <PropertyColumn Property="c => (c.UpdateTime ?? c.CreateTime).LocalDateTime" Format="yyyy-MM-dd HH:mm" Title="更新时间"></PropertyColumn>
        <ActionColumn Title="操作">
            <Space>
                <SpaceItem>
                    <a @onclick="() => EditLlmModel(context)">编辑</a>
                </SpaceItem>

                <SpaceItem>
                    <Popconfirm Title="确认要删除吗？"
                                OnConfirm="_=>DeleteLlmModelAsync(context.Id)"
                                OkText="Yes"
                                CancelText="No">
                        <a style="color:red">删除</a>
                    </Popconfirm>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </ColumnDefinitions>

    <PaginationTemplate>
        <div style="margin:15px 0;float:right">
            <Pagination Total="@pageList.Total" PageSize="@request.PageSize" Current="@request.Page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
        </div>
    </PaginationTemplate>

</Table>


<Drawer Closable="true" Width="700" Visible="isShowEdit" Title='(editId == null ? "新增 LLM 模型" : "编辑 LLM 模型")' OnClose="() => isShowEdit = false">
    <Template style="height:90%">

        <Form Model="@editLlmModel" OnFinish="SaveLlmModelAsync">

            <FormItem>
                <Text>名称</Text>
                <Input Placeholder="如: DeepSeek V3" @bind-Value="@context.Name" />
            </FormItem>

            <FormItem>
                <Text>模型标识</Text>
                <Input Placeholder="如: deepseek-chat" @bind-Value="@context.ModelId" />
            </FormItem>

            <FormItem>
                <Text>端点地址</Text>
                <Input Placeholder="如: https://api.deepseek.com/chat/completions" @bind-Value="@context.Endpoint" />
            </FormItem>

            <FormItem>
                <Text>接口密钥</Text>
                <InputPassword Placeholder="请输入接口密钥" @bind-Value="@context.ApiKey" />
            </FormItem>

            <FormItem>
                <Text>协议类型</Text>
                <Select TItem="int" TItemValue="int" @bind-Value="@context.ProtocolType" Style="width: 100%">
                    <SelectOption Value="0" Label="Chat"></SelectOption>
                    <SelectOption Value="1" Label="Responses（预留）" Disabled></SelectOption>
                </Select>
            </FormItem>

            <FormItem>
                <Text>是否启用</Text>
                <Switch @bind-Value="@editLlmModel.IsEnable" CheckedChildren="是" UnCheckedChildren="否" />
            </FormItem>

            <FormItem>
                <Text>备注</Text>
                <TextArea @bind-Value="@context.Remark" MinRows="2" MaxRows="6" style="width:100%" />
            </FormItem>

            <Row Gutter="24">
                <AntDesign.Col Span="24">
                    <div style="float:right;margin-top:12px">
                        <Button Type="@ButtonType.Primary" HtmlType="submit" Loading="@saveLoading">保存</Button>
                        <Button Type="@ButtonType.Default" @onclick="() => isShowEdit = false">取消</Button>
                    </div>
                </AntDesign.Col>
            </Row>

        </Form>

    </Template>
</Drawer>


@code {

    override protected async Task OnParametersSetAsync()
    {
        await GetLlmModelListAsync();
    }

    LlmModelPageRequestDto request = new() { PageSize = 10 };

    bool tableLoading = false;
    PageListDto<LlmModelDto> pageList = new();

    async Task GetLlmModelListAsync()
    {
        tableLoading = true;

        var url = StringHelper.ModelToUriParam(request, "LlmModel/GetLlmModelList");
        var retData = await Http.GetFromJsonAsync<PageListDto<LlmModelDto>>(url, JsonHelper.DeserializeOpts);

        if (retData != null)
        {
            pageList = retData;
        }

        tableLoading = false;
        StateHasChanged();
    }

    async Task HandleSearchAsync(EditContext editContext)
    {
        request.Page = 1;
        await GetLlmModelListAsync();
    }

    async Task HandleReset()
    {
        request = new LlmModelPageRequestDto { PageSize = request.PageSize };
        await GetLlmModelListAsync();
    }

    async Task PageChange(PaginationEventArgs args)
    {
        if (request.Page != args.Page)
        {
            request.Page = args.Page;
        }

        if (request.PageSize != args.PageSize)
        {
            request.PageSize = args.PageSize;
        }

        await GetLlmModelListAsync();
    }

    Func<PaginationTotalContext, string> showTotal = pageList => $"共 {pageList.Total} 条";

    bool isShowEdit = false;
    bool saveLoading = false;
    long? editId;
    EditLlmModelDto editLlmModel = new();

    static string ProtocolTypeText(int protocolType) => protocolType switch
    {
        0 => "Chat",
        1 => "Responses",
        _ => "未知"
    };

    void EditLlmModel(LlmModelDto? row = null)
    {
        if (row == null)
        {
            editId = null;
            editLlmModel = new EditLlmModelDto { IsEnable = true };
        }
        else
        {
            editId = row.Id;
            editLlmModel = new EditLlmModelDto
            {
                Name = row.Name,
                ModelId = row.ModelId,
                Endpoint = row.Endpoint,
                ApiKey = row.ApiKey,
                ProtocolType = row.ProtocolType,
                IsEnable = row.IsEnable,
                Remark = row.Remark
            };
        }

        isShowEdit = true;
    }

    async Task SaveLlmModelAsync()
    {
        if (string.IsNullOrWhiteSpace(editLlmModel.Name))
        {
            Message.Error("名称不可以空");
            return;
        }

        if (string.IsNullOrWhiteSpace(editLlmModel.ModelId))
        {
            Message.Error("模型标识不可以空");
            return;
        }

        if (string.IsNullOrWhiteSpace(editLlmModel.Endpoint))
        {
            Message.Error("端点地址不可以空");
            return;
        }

        if (string.IsNullOrWhiteSpace(editLlmModel.ApiKey))
        {
            Message.Error("接口密钥不可以空");
            return;
        }

        saveLoading = true;
        try
        {
            using HttpResponseMessage httpResponse = editId == null
                ? await Http.PostAsJsonAsync("LlmModel/CreateLlmModel", editLlmModel, JsonHelper.SerializeOpts)
                : await Http.PostAsJsonAsync("LlmModel/UpdateLlmModel?id=" + editId.Value, editLlmModel, JsonHelper.SerializeOpts);

            if (httpResponse.IsSuccessStatusCode)
            {
                Message.Success("保存成功");
                isShowEdit = false;
                await GetLlmModelListAsync();
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("保存失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
        finally
        {
            saveLoading = false;
            StateHasChanged();
        }
    }

    async Task DeleteLlmModelAsync(long id)
    {
        try
        {
            using var httpResponse = await Http.DeleteAsync("LlmModel/DeleteLlmModel?id=" + id);

            if (httpResponse.IsSuccessStatusCode)
            {
                Message.Success("删除成功");
                await GetLlmModelListAsync();
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("删除失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
    }
}
