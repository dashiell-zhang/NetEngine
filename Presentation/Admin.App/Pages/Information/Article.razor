@page "/information/article"
@using Application.Model.Site.Article
@inject ImageUploadService imageUploadService
@attribute [ReuseTabsPageTitle("文章管理")]

<div style="margin-bottom:10px">

    @if (functionList.Contains("article-add"))
    {
        <Button Icon="plus" Type="@ButtonType.Primary" OnClick="() => EditArticleAsync()">添加</Button>
    }

</div>
<Table TItem="ArticleDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

    <ColumnDefinitions>
        <PropertyColumn Property="c => c.Title" Title="标题"></PropertyColumn>
        <PropertyColumn Property="c => c.CategoryName" Title="类别"></PropertyColumn>
        <PropertyColumn Property="c => c.IsRecommend" Title="是否推荐"></PropertyColumn>
        <PropertyColumn Property="c => c.IsDisplay" Title="显示状态"></PropertyColumn>
        <PropertyColumn Property="c => c.ClickCount" Title="点击量"></PropertyColumn>
        <PropertyColumn Property="c => c.CreateTime.LocalDateTime" Format="yyyy-MM-dd HH:mm" Title="创建时间"></PropertyColumn>

        <ActionColumn Title="操作">
            <Space>

                @if (functionList.Contains("article-edit"))
                {

                    <SpaceItem>
                        <a @onclick="() => EditArticleAsync(context)">编辑</a>
                    </SpaceItem>
                }

                @if (functionList.Contains("article-delete"))
                {
                    <SpaceItem>
                        <Popconfirm Title="确认要删除吗？"
                                    OnConfirm="_=>DeleteArticleAsync(context.Id)"
                                    OkText="Yes"
                                    CancelText="No">
                            <a style="color:red">删除</a>
                        </Popconfirm>

                    </SpaceItem>
                }

            </Space>
        </ActionColumn>
    </ColumnDefinitions>

    <PaginationTemplate>
        <div style="margin:15px 0;float:right">
            <Pagination Total="@pageList.Total" PageSize="pageSize" Current="page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
        </div>
    </PaginationTemplate>

</Table>


@{
    RenderFragment editFooter = @<Template>
        <Button OnClick="SaveArticleAsync" Type="@ButtonType.Primary" Loading="@saveLoading">保存</Button>
        <Button OnClick="() => isShowEditArticle = false" @key="@("back")">取消</Button>
    </Template>;
}


<Modal Title="文章信息" Style="width:1160px;" Visible="@isShowEditArticle" OnCancel="() => isShowEditArticle = false" Footer="@editFooter">

    <Form @ref="@_editArticleForm" Model="@editArticle" LabelColSpan="2" WrapperColSpan="22" Class="ueditorBody">

        <Tabs Type="@TabType.Card">

            <TabPane Key="1" Tab="基本信息">

                <FormItem Label="所属栏目">
                    <TreeSelect TItem="TreeSelectDto" TItemValue="string" Style="width: 190px" DataSource="selectCategoryList" @bind-Value="@context.CategoryId" Placeholder="请选择所属栏目" TreeDefaultExpandAll ChildrenExpression="node => node.DataItem.Children" DisabledExpression="node => node.DataItem.IsDisabled" TitleExpression="node => node.DataItem.Title" KeyExpression="node => node.DataItem.Key" IsLeafExpression="node => node.DataItem.Children == null"></TreeSelect>
                </FormItem>

                <FormItem Label="标题">
                    <Input Placeholder="请输入标题" @bind-Value="@context.Title" style="width: 30em" />
                </FormItem>

                <FormItem Label="是否显示">
                    <Switch @bind-Value="@context.IsDisplay" CheckedChildren="是" UnCheckedChildren="否" />
                </FormItem>

                <FormItem Label="是否推荐">
                    <Switch @bind-Value="@context.IsRecommend" CheckedChildren="是" UnCheckedChildren="否" />
                </FormItem>

                <FormItem Label="排序">
                    <Input Placeholder="请输入排序值" Type="InputType.Number" @bind-Value="@context.Sort" style="width: 190px" />
                </FormItem>

                <FormItem Label="点击量">
                    <Input Placeholder="请输入点击量" Type="InputType.Number" @bind-Value="@context.ClickCount" style="width: 190px" />
                </FormItem>

                <FormItem Label="封面图">

                    <InputFile id="fileInput" OnChange="@UploadImgageAsync" hidden multiple accept=".png,.jpg" />
                    <Upload Name="files">
                        <label class="ant-btn" for="fileInput">
                            <Icon Type="upload" />
                            上传图片
                        </label>
                    </Upload>

                    <Upload FileList="fileList" ListType="UploadListType.PictureCard" OnPreview="(file) => PreviewImg(file)" OnRemove=" (file)=> DeleteImgAsync(file)" ShowButton=false style="margin-top:8px"></Upload>

                    <Image PreviewSrc="@previewImgUrl" Style="display: none;" @bind-PreviewVisible="isPreviewImg" />

                </FormItem>

            </TabPane>

            <TabPane Key="2" Tab="详细内容" ForceRender="true">
                <FormItem Label="摘要">
                    <TextArea ShowCount MaxLength=255 Placeholder="不填写则自动截取内容前255字符" @bind-Value="@context.Digest" MinRows="4" MaxRows="6" style="width:50em;min-height:80px" />
                </FormItem>

                <FormItem Label="内容">
                    <TextArea Id="Content" @bind-Value="@context.Content" />
                </FormItem>
            </TabPane>

        </Tabs>

    </Form>
</Modal>


@code {

    async Task UploadImgageAsync(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            try
            {
                var uploadResult = await imageUploadService.UploadImageAsync(file, new ImageUploadRequest
                {
                    Business = "Article",
                    Key = fileKey,
                    Sign = "cover",
                    IsPublicRead = true
                });
                string fileUrl = await JS.InvokeAsync<string>("CreateObjectUrl", uploadResult.FileBytes, uploadResult.ContentType);

                fileList.Add(new UploadFileItem()
                {
                    Id = uploadResult.FileId,
                    FileName = uploadResult.FileName,
                    Url = fileUrl,
                    State = UploadState.Success
                });
            }
            catch (Exception ex)
            {
                Message.Error(file.Name + " 上传失败 " + ex.Message);
            }

            StateHasChanged();
        }

    }


    private Form<EditArticleDto>? _editArticleForm;

    bool isPreviewImg = false;
    string? previewImgUrl;
    long fileKey;
    bool saveLoading = false;
    List<UploadFileItem> fileList = new();

    [Parameter]
    public string? channelId { get; set; }

    List<TreeSelectDto>? selectCategoryList;


    List<string> functionList = new();

    override protected async Task OnInitializedAsync()
    {
        functionList = await userContextService.GetFunctionList();
    }

    override protected async Task OnParametersSetAsync()
    {
        var getArticleListTask = GetArticleListAsync();
        var getCategorySelectListTask = GetCategorySelectListAsync();

        await Task.WhenAll(getArticleListTask, getCategorySelectListTask);
    }



    async Task GetCategorySelectListAsync()
    {
        List<CategorySelectDto> parentKVList = new();

        var kvList = await Http.GetFromJsonAsync<List<CategorySelectDto>>("Article/GetCategorySelectList?channelId=" + channelId, JsonHelper.DeserializeOpts);

        if (kvList != null)
        {
            parentKVList.AddRange(kvList);

            selectCategoryList = CategoryTreeConvert(parentKVList)!.ToList();
        }

    }

    private IEnumerable<TreeSelectDto>? CategoryTreeConvert(List<CategorySelectDto>? keyValueChildren)
    {
        return keyValueChildren?.Select(t => new TreeSelectDto
        {
            Key = t.Id.ToString()!,
            Title = t.Name!.ToString()!,
            Children = CategoryTreeConvert(t.ChildList),
            IsDisabled = false
        }).ToList();
    }

    bool tableLoading = false;
    int page = 1;
    int pageSize = 10;
    PageListDto<ArticleDto> pageList = new();

    async Task GetArticleListAsync()
    {
        tableLoading = true;
        var retData = await Http.GetFromJsonAsync<PageListDto<ArticleDto>>("Article/GetArticleList?channelId=" + channelId + "&page=" + page + "&pageSize=" + pageSize, JsonHelper.DeserializeOpts);

        if (retData != null)
        {
            pageList = retData;
        }

        tableLoading = false;
        StateHasChanged();
    }

    async Task PageChange(PaginationEventArgs args)
    {
        if (page != args.Page)
        {
            page = args.Page;
        }

        if (pageSize != args.PageSize)
        {
            pageSize = args.PageSize;
        }

        await GetArticleListAsync();
    }
    Func<PaginationTotalContext, string> showTotal = pageList => $"共 {pageList.Total} 条";


    bool isShowEditArticle = false;
    EditArticleDto editArticle = new();
    long articleId;


    async Task EditArticleAsync(ArticleDto? article = null)
    {

        editArticle = new();

        foreach (var item in fileList)
        {
            if (item.Url.StartsWith("blob"))
            {
                JS.InvokeAsync<string>("RevokeObjectUrl", item.Url);
            }
        }

        fileList = new();
        articleId = default;

        if (article != null)
        {

            fileKey = article.Id;

            articleId = article.Id;
            editArticle.CategoryId = article.CategoryId.ToString();

            editArticle.Title = article.Title;
            editArticle.Sort = article.Sort;
            editArticle.ClickCount = article.ClickCount;
            editArticle.Digest = article.Digest;
            editArticle.Content = article.Content;
            editArticle.IsDisplay = article.IsDisplay;
            editArticle.IsRecommend = article.IsRecommend;

            if (article.CoverImageList != null && article.CoverImageList.Any())
            {
                fileList = article.CoverImageList?.Select(t => new UploadFileItem
                {
                    Id = t.Id.ToString(),
                    FileName = "coverImg.jpg",
                    Url = t.Url,
                    State = UploadState.Success
                }).ToList()!;
            }

        }
        else
        {
            fileKey = await Http.GetFromJsonAsync<long>("Base/GetSnowflakeId", JsonHelper.DeserializeOpts);
            editArticle.IsDisplay = true;
            editArticle.Sort = 99;
            editArticle.CategoryId = "";
        }

        var getCategorySelectListTask = GetCategorySelectListAsync();

        isShowEditArticle = true;

        StateHasChanged();

        await Task.WhenAll(getCategorySelectListTask, Task.Delay(200));

        JS.InvokeVoidAsync("InitUeditor", "Content", 370);

    }


    async Task SaveArticleAsync()
    {
        editArticle.Content = await JS.InvokeAsync<string>("GetUeditorContent", "Content");

        if (_editArticleForm!.Validate())
        {

            saveLoading = true;

            if (articleId == default)
            {
                using var httpResponse = await Http.PostAsJsonAsync<EditArticleDto>("Article/CreateArticle?fileKey=" + fileKey, editArticle, JsonHelper.SerializeOpts);

                if (httpResponse.IsSuccessStatusCode)
                {
                    Message.Success("添加成功");
                }
            }
            else
            {
                using var httpResponse = await Http.PostAsJsonAsync<EditArticleDto>("Article/UpdateArticle?articleId=" + articleId, editArticle, JsonHelper.SerializeOpts);
                if (httpResponse.IsSuccessStatusCode)
                {
                    Message.Success("编辑成功");
                }
            }

            saveLoading = false;

            await GetArticleListAsync();

            isShowEditArticle = false;
        }
    }


    async Task DeleteArticleAsync(long articleId)
    {
        using var httpResponse = await Http.DeleteAsync("Article/DeleteArticle?id=" + articleId);
        if (httpResponse.IsSuccessStatusCode)
        {
            await GetArticleListAsync();
            Message.Success("删除成功");
        }
    }


    void PreviewImg(UploadFileItem file)
    {
        isPreviewImg = true;
        previewImgUrl = file.Url;
    }

    async Task<bool> DeleteImgAsync(UploadFileItem file)
    {
        using var httpResponse = await Http.DeleteAsync("File/DeleteFile?id=" + file.Id);

        if (httpResponse.IsSuccessStatusCode)
        {
            var retValue = await httpResponse.Content.ReadAsStringAsync();

            if (Convert.ToBoolean(retValue))
            {
                fileList.Remove(file);

                return true;
            }
        }

        return false;
    }

}
