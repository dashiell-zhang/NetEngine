@code {

    List<string> functionList = new();

    override protected async Task OnInitializedAsync()
    {
        functionList = await userContextService.GetFunctionList();
    }

    override protected async Task OnParametersSetAsync()
    {
        await GetLogListAsync();
    }

    LogPageRequestDto request = new() { PageSize = 10 };

    bool tableLoading = false;
    PageListDto<LogDto> pageList = new();

    async Task GetLogListAsync()
    {
        tableLoading = true;
        var url = StringHelper.ModelToUriParam(request, "Operations/GetLogList");
        var retData = await Http.GetFromJsonAsync<PageListDto<LogDto>>(url, JsonHelper.DeserializeOpts);

        if (retData != null)
        {
            pageList = retData;
        }

        tableLoading = false;
        StateHasChanged();
    }

    async Task HandleSearchAsync(EditContext editContext)
    {
        request.Page = 1;
        await GetLogListAsync();
    }

    async Task HandleReset()
    {
        request = new LogPageRequestDto { PageSize = request.PageSize };
        await GetLogListAsync();
    }

    async Task PageChange(PaginationEventArgs args)
    {
        if (request.Page != args.Page)
        {
            request.Page = args.Page;
        }

        if (request.PageSize != args.PageSize)
        {
            request.PageSize = args.PageSize;
        }

        await GetLogListAsync();
    }

    Func<PaginationTotalContext, string> showTotal = pageList => $"共 {pageList.Total} 条";

    bool isShowDetail = false;
    LogDto? detail;
    string? detailContent;

    /// <summary>
    /// 返回当前页已加载的日志数量
    /// </summary>
    int CurrentPageCount() => pageList.List?.Count ?? 0;


    /// <summary>
    /// 返回当前等级筛选文案
    /// </summary>
    string CurrentLevelText() => string.IsNullOrWhiteSpace(request.Level) ? "全部等级" : request.Level;


    /// <summary>
    /// 返回当前时间范围文案
    /// </summary>
    string CurrentTimeRangeText()
    {
        if (request.StartTime == null && request.EndTime == null)
        {
            return "全部时间";
        }

        var startText = request.StartTime?.ToString("MM-dd HH:mm") ?? "未设开始";
        var endText = request.EndTime?.ToString("MM-dd HH:mm") ?? "未设结束";
        return $"{startText} - {endText}";
    }


    /// <summary>
    /// 返回详情中的时间文案
    /// </summary>
    string DetailTimeText() => detail == null ? "-" : detail.CreateTime.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss");


    /// <summary>
    /// 返回日志等级展示文案
    /// </summary>
    string LogLevelText(string? level) => string.IsNullOrWhiteSpace(level) ? "未知" : level;


    /// <summary>
    /// 返回日志等级标签颜色
    /// </summary>
    string LogLevelColor(string? level) => level switch
    {
        "Trace" => "#94a3b8",
        "Debug" => "#38bdf8",
        "Information" => "#3b82f6",
        "Warning" => "#f59e0b",
        "Error" => "#f97316",
        "Critical" => "#dc2626",
        "None" => "#64748b",
        _ => "#9ca3af"
    };

    void ViewLog(LogDto row)
    {
        detail = row;
        detailContent = row.Content;
        isShowDetail = true;
        StateHasChanged();
    }
}
