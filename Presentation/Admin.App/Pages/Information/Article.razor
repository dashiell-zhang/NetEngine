        border-radius: 12px;
        border-color: #dbe7f5;
        background: #ffffff;
        box-shadow: none;
        min-height: 40px;
    }

    .article-editor .ant-select-single:not(.ant-select-customize-input) .ant-select-selector {
        display: flex;
        align-items: center;
    }

    .article-editor .ant-select-selection-item,
    .article-editor .ant-select-selection-placeholder {
        line-height: 38px;
    }

    .article-editor .ant-form-item-label > label {
        font-size: 12px;
        font-weight: 700;
        color: #42556d;
    }

    .article-editor .ant-form-vertical .ant-form-item-label {
        padding-bottom: 6px;
    }

    .ant-select-dropdown:has(.ant-tree) {
        box-sizing: border-box;
        padding: 8px 0;
        border-radius: 16px;
        border: 1px solid #dbe7f5;
        background: #ffffff;
        box-shadow: 0 18px 36px rgba(59, 83, 119, 0.12);
        overflow: hidden;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree {
        width: 100%;
        box-sizing: border-box;
        padding: 4px 8px;
        background: transparent;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-list {
        background: transparent;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-list-holder {
        padding-right: 2px;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-list-holder-inner > .ant-tree-treenode:first-child {
        margin-bottom: 6px;
        padding-bottom: 6px;
        border-bottom: 1px dashed #e4edf7;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-treenode {
        align-items: center;
        min-height: 34px;
        padding: 1px 0;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-switcher {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 32px;
        margin-right: 2px;
        border-radius: 8px;
        color: #7b8ba1;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-switcher:hover {
        background: #f3f7fc;
        color: #4b5f78;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-indent-unit {
        width: 16px;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-node-content-wrapper {
        display: flex;
        align-items: center;
        min-height: 32px;
        padding: 0 2px;
        border-radius: 10px;
        color: #1d3049;
        background: transparent;
        transition: color 0.2s ease;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-title {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        padding: 0 10px;
        border-radius: 8px;
        line-height: 1.4;
        transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-node-content-wrapper:hover {
        color: #1d4ed8;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-node-content-wrapper:hover .ant-tree-title {
        background: #f3f8ff;
    }

    .ant-select-dropdown:has(.ant-tree) .ant-tree-node-content-wrapper.ant-tree-node-selected {
        background: transparent;
        color: #1d4ed8;
