@inherits LayoutComponentBase
@using Application.Model.User.User
@using Microsoft.IdentityModel.JsonWebTokens;

<Layout Style="min-height: 100vh;">

    <Sider Class="main-layout-sider" Collapsible Collapsed=@collapsed CollapsedChanged=@onCollapse Style="height: 100vh;position: fixed;left: 0;z-index:3;overflow:hidden;">
        <div class="main-layout-sider__inner">
            <div class="logo main-layout-sider__logo" style="height: 32px;margin: 16px;display:flex">
                <img src="img/logo.png" style="height:29px" />
                <h1 class="main-layout-sider__brand" style="color:#fff;font-size:20px;margin-left:17px">NetEngine</h1>
            </div>

            <div class="main-layout-sider__menu-shell">
                <div class="main-layout-sider__menu">
                    <Menu Class="main-layout-sider__menu-list" Theme="MenuTheme.Dark" DefaultSelectedKeys=@(new[]{"1"}) Mode="MenuMode.Inline">

                        @if (functionList.Contains("information"))
                        {
                            <SubMenu TitleTemplate=subArticle>
                                @if (functionList.Contains("article"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="information/article">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="file-text" Theme="IconThemeType.Outline" />
                                            <span>文章管理</span>
                                        </a>
                                    </MenuItem>
                                }

                                @if (functionList.Contains("category"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="information/category">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="appstore" Theme="IconThemeType.Outline" />
                                            <span>栏目管理</span>
                                        </a>
                                    </MenuItem>
                                }
                            </SubMenu>
                        }

                        @if (functionList.Contains("systemset"))
                        {
                            <SubMenu TitleTemplate=subSystemSet>
                                @if (functionList.Contains("user"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="systemset/user">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="user" Theme="IconThemeType.Outline" />
                                            <span>用户管理</span>
                                        </a>
                                    </MenuItem>
                                }

                                @if (functionList.Contains("role"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="systemset/role">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="team" Theme="IconThemeType.Outline" />
                                            <span>角色管理</span>
                                        </a>
                                    </MenuItem>
                                }

                                @if (functionList.Contains("link"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="systemset/link">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="link" Theme="IconThemeType.Outline" />
                                            <span>友链管理</span>
                                        </a>
                                    </MenuItem>
                                }

                                @if (functionList.Contains("info"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="systemset/site">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="info-circle" Theme="IconThemeType.Outline" />
                                            <span>信息维护</span>
                                        </a>
                                    </MenuItem>
                                }
                            </SubMenu>
                        }

                        @if (functionList.Contains("operations"))
                        {
                            <SubMenu TitleTemplate=subOperations>
                                @if (functionList.Contains("tasksetting"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="operations/scheduletasksetting">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="calendar" Theme="IconThemeType.Outline" />
                                            <span>定时任务配置</span>
                                        </a>
                                    </MenuItem>
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="operations/queuetasksetting">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="deployment-unit" Theme="IconThemeType.Outline" />
                                            <span>队列任务配置</span>
                                        </a>
                                    </MenuItem>
                                }

                                @if (functionList.Contains("queuetask"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="operations/queuetask">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="unordered-list" Theme="IconThemeType.Outline" />
                                            <span>队列任务</span>
                                        </a>
                                    </MenuItem>
                                }

                                @if (functionList.Contains("llmapp"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="operations/llmmodel">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="robot" Theme="IconThemeType.Outline" />
                                            <span>LLM模型管理</span>
                                        </a>
                                    </MenuItem>
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="operations/llmapp">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="appstore" Theme="IconThemeType.Outline" />
                                            <span>LLM应用</span>
                                        </a>
                                    </MenuItem>
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="operations/llmconversation">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="message" Theme="IconThemeType.Outline" />
                                            <span>LLM会话日志</span>
                                        </a>
                                    </MenuItem>
                                }

                                @if (functionList.Contains("log"))
                                {
                                    <MenuItem>
                                        <a class="main-layout-sider__menu-link" href="operations/log">
                                            <Icon Class="main-layout-sider__menu-link-icon" Type="file-search" Theme="IconThemeType.Outline" />
                                            <span>系统日志</span>
                                        </a>
                                    </MenuItem>
                                }
                            </SubMenu>
                        }

                    </Menu>
                </div>
            </div>
        </div>
    </Sider>

    <Header Class="site-layout-background main-layout-header" Style="height: 48px;padding: 0 20px;line-height: 39px;position:fixed;width:100%;right:0;z-index:2;">
        <div class="main-layout-header__actions">
            <Dropdown Trigger="@(new Trigger[] { Trigger.Click })">
                <Overlay>
                    <Menu Class="main-layout-user-menu">
                        <MenuItem Class="main-layout-user-menu__item" OnClick="Logout">
                            <Icon Type="logout" Theme="IconThemeType.Outline" />
                            退出登录
                        </MenuItem>
                    </Menu>
                </Overlay>
                <ChildContent>
                    <div class="main-layout-user-trigger">
                        <Avatar Class="main-layout-user-trigger__avatar" Size="@(OneOf<AvatarSize,string>.FromT1("34"))" Icon="user" />
                        <span class="main-layout-user-trigger__name">@user.Name</span>
                        <Icon Class="main-layout-user-trigger__caret" Type="down" Theme="IconThemeType.Outline" />
                    </div>
                </ChildContent>
            </Dropdown>
        </div>
    </Header>

    <Layout Class="site-layout" Style=@leftLayoutStyle>
        <Content Style="margin:0 0px;margin-top:4px;">
            <ReuseTabs Class="MainTab" TabPaneTemplate="@tabPaneTemplate">
            </ReuseTabs>
        </Content>
    </Layout>

</Layout>

<style>
    .main-layout-header {
        backdrop-filter: blur(14px);
    }

    .main-layout-header__actions {
        float: right;
        display: flex;
        align-items: center;
        height: 100%;
    }

    .main-layout-user-trigger {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 34px;
        padding: 2px 8px 2px 3px;
        border: 1px solid transparent;
        border-radius: 10px;
        background: transparent;
        box-shadow: none;
        color: #1f3c5a;
        cursor: pointer;
        transition: color 0.18s ease;
        user-select: none;
    }

    .main-layout-user-trigger:hover {
        background: transparent;
        border-color: transparent;
        box-shadow: none;
        color: #16324c;
    }

    .main-layout-user-trigger__avatar.ant-avatar {
        background: linear-gradient(180deg, #8fd86f, #6fc554);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22);
        transition: box-shadow 0.18s ease, filter 0.18s ease;
    }

    .main-layout-user-trigger:hover .main-layout-user-trigger__avatar.ant-avatar {
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22), 0 4px 10px rgba(72, 123, 44, 0.14);
        filter: saturate(1.03);
    }

    .main-layout-user-trigger__name {
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.01em;
        line-height: 1;
        white-space: nowrap;
        transition: color 0.18s ease;
    }

    .main-layout-user-trigger__caret {
        font-size: 10px;
        color: rgba(31, 60, 90, 0.46);
        transition: color 0.18s ease;
    }

    .main-layout-user-trigger:hover .main-layout-user-trigger__caret {
        color: rgba(22, 50, 76, 0.68);
    }

    .main-layout-user-menu.ant-menu,
    .main-layout-user-menu.ant-dropdown-menu {
        min-width: 136px;
        padding: 6px;
        border: 1px solid rgba(125, 169, 220, 0.18);
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.96);
        box-shadow: 0 12px 24px rgba(17, 44, 77, 0.1);
    }

    .main-layout-user-menu__item.ant-menu-item,
    .main-layout-user-menu__item.ant-dropdown-menu-item {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0;
        border-radius: 10px;
        color: #183654;
        font-weight: 500;
    }

    .main-layout-user-menu__item.ant-menu-item:hover,
    .main-layout-user-menu__item.ant-dropdown-menu-item:hover {
        background: linear-gradient(90deg, rgba(69, 160, 255, 0.12), rgba(69, 160, 255, 0.03));
    }

    .main-layout-user-menu__item .anticon {
        color: rgba(36, 96, 168, 0.82);
    }

    .main-layout-sider.ant-layout-sider {
        background:
            radial-gradient(circle at top, rgba(66, 153, 225, 0.16), transparent 30%),
            linear-gradient(180deg, #081a2d 0%, #0b2238 100%);
        box-shadow: 12px 0 30px rgba(5, 18, 34, 0.18);
    }

    .main-layout-sider .ant-layout-sider-children {
        height: 100%;
    }

    .main-layout-sider__inner {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 10px 0 16px;
    }

    .main-layout-sider__logo {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        min-width: 0;
        gap: 12px;
        margin: 8px 12px 8px !important;
        padding: 0 8px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .main-layout-sider__logo img {
        flex-shrink: 0;
    }

    .main-layout-sider__brand {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        margin: 0 !important;
        font-weight: 700;
        letter-spacing: 0.02em;
        text-shadow: 0 4px 16px rgba(0, 0, 0, 0.16);
        transition: opacity 0.2s ease, margin 0.2s ease, width 0.2s ease;
        white-space: nowrap;
    }

    .main-layout-sider.ant-layout-sider-collapsed .main-layout-sider__brand {
        width: 0;
        margin-left: 0 !important;
        opacity: 0;
    }

    .main-layout-sider__menu-shell {
        position: relative;
        flex: 1;
        min-height: 0;
        padding: 0 8px 0 12px;
    }

    .main-layout-sider__menu-shell::after {
        position: absolute;
        left: 12px;
        right: 14px;
        z-index: 1;
        height: 18px;
        content: "";
        pointer-events: none;
    }

    .main-layout-sider__menu-shell::after {
        bottom: 0;
        background: linear-gradient(0deg, rgba(11, 34, 56, 0.96), rgba(11, 34, 56, 0));
    }

    .main-layout-sider__menu {
        height: 100%;
        overflow-x: hidden;
        overflow-y: auto;
        padding: 8px 4px 20px 0;
        scrollbar-width: thin;
        scrollbar-color: rgba(151, 202, 255, 0.34) transparent;
    }

    .main-layout-sider__menu::-webkit-scrollbar {
        width: 8px;
    }

    .main-layout-sider__menu::-webkit-scrollbar-track {
        background: transparent;
    }

    .main-layout-sider__menu::-webkit-scrollbar-thumb {
        background: rgba(151, 202, 255, 0.22);
        border: 2px solid transparent;
        border-radius: 999px;
        background-clip: padding-box;
    }

    .main-layout-sider__menu:hover::-webkit-scrollbar-thumb {
        background: rgba(151, 202, 255, 0.42);
        border: 2px solid transparent;
        background-clip: padding-box;
    }

    .main-layout-sider__menu-list.ant-menu,
    .main-layout-sider__menu-list.ant-menu-dark {
        background: transparent;
    }

    .main-layout-sider__menu-list.ant-menu-inline {
        border-right: 0;
    }

    .main-layout-sider__menu-list .ant-menu-submenu-title,
    .main-layout-sider__menu-list .ant-menu-item {
        width: auto;
        margin: 6px 0;
        border-radius: 12px;
        padding-right: 14px !important;
    }

    .main-layout-sider__menu-list .ant-menu-submenu-title {
        padding-left: 16px !important;
    }

    .main-layout-sider__section-title {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        min-width: 0;
    }

    .main-layout-sider__section-title > span:last-child {
        margin-left: 0 !important;
    }

    .main-layout-sider__section-icon {
        flex-shrink: 0;
        font-size: 13px;
    }

    .main-layout-sider__menu-list .ant-menu-submenu-open > .ant-menu-submenu-title {
        margin-bottom: 2px;
    }

    .main-layout-sider__menu-list.ant-menu-dark .ant-menu-sub {
        position: relative;
        margin: 2px 0 10px;
        padding: 6px 8px !important;
        padding-left: 0 !important;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.026);
    }

    .main-layout-sider__menu-list .ant-menu-sub .ant-menu-item {
        margin: 4px 0;
        padding-left: 44px !important;
        color: rgba(226, 235, 244, 0.82);
    }

    .main-layout-sider__menu-link {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        width: 100%;
        min-width: 0;
    }

    .main-layout-sider__menu-link span {
        min-width: 0;
    }

    .main-layout-sider__menu-link > span:last-child {
        margin-left: 0 !important;
    }

    .main-layout-sider__menu-link-icon {
        flex-shrink: 0;
        font-size: 13px;
        color: rgba(183, 216, 255, 0.88);
    }

    .main-layout-sider__menu-list.ant-menu-dark .ant-menu-item-selected {
        background-color: rgba(69, 160, 255, 0.14) !important;
        background-image: linear-gradient(90deg, rgba(69, 160, 255, 0.18), rgba(69, 160, 255, 0.05));
    }

    .main-layout-sider__menu-list.ant-menu-dark .ant-menu-submenu-selected > .ant-menu-submenu-title,
    .main-layout-sider__menu-list.ant-menu-dark .ant-menu-submenu-active > .ant-menu-submenu-title {
        background-color: rgba(69, 160, 255, 0.08) !important;
        background-image: linear-gradient(90deg, rgba(69, 160, 255, 0.12), rgba(69, 160, 255, 0.03));
    }

    .main-layout-sider__menu-list.ant-menu-dark .ant-menu-item:hover,
    .main-layout-sider__menu-list.ant-menu-dark .ant-menu-submenu-title:hover {
        background: linear-gradient(90deg, rgba(69, 160, 255, 0.22), rgba(69, 160, 255, 0.07));
    }

    .MainTab > :first-child {
        width: 80%;
        padding-left: 5px;
        position: fixed;
        z-index: 2;
    }
</style>

@code {
    string leftLayoutStyle = "margin-left:200px";

    RenderFragment subSystemSet =
    @<span class="main-layout-sider__section-title">
        <Icon Class="main-layout-sider__section-icon" Type="control" Theme="IconThemeType.Outline" />
        <span>系统设置</span>
    </span>;

    RenderFragment subOperations =
    @<span class="main-layout-sider__section-title">
        <Icon Class="main-layout-sider__section-icon" Type="tool" Theme="IconThemeType.Outline" />
        <span>运维管理</span>
    </span>;

    RenderFragment subArticle =
    @<span class="main-layout-sider__section-title">
        <Icon Class="main-layout-sider__section-icon" Type="read" Theme="IconThemeType.Outline" />
        <span>资讯管理</span>
    </span>
    ;

    RenderFragment<AntDesign.ReuseTabsPageItem> tabPaneTemplate = context =>
    @<div style="padding-top:30px;">
        <div Class="site-layout-background">
            @context.Body
        </div>
    </div>;

    bool collapsed;

    void onCollapse(bool collapsed)
    {
        if (collapsed)
        {
            leftLayoutStyle = "margin-left:80px";

        }
        else
        {
            leftLayoutStyle = "margin-left:200px";

        }

        this.collapsed = collapsed;
    }


    protected override async Task OnInitializedAsync()
    {
        await AuthenticationAsync();
    }

    UserDto user = new();

    List<string> functionList = new();


    private async Task AuthenticationAsync()
    {
        var authorization = LocalStorage.GetItemAsString("Authorization");

        if (string.IsNullOrEmpty(authorization))
        {
            NavigationManager.NavigateTo("login");
        }
        else
        {
            JsonWebToken jsonWebToken = new(authorization);

            var expTimeL = Convert.ToInt64(jsonWebToken.GetClaim("exp").Value);

            var expTime = DateTimeOffset.FromUnixTimeSeconds(expTimeL);

            if (expTime < DateTimeOffset.UtcNow)
            {
                NavigationManager.NavigateTo("login");
            }
            else
            {
                try
                {
                    var userRet = await userContextService.GetUser();

                    if (userRet != null)
                    {
                        user = userRet;

                        functionList = await userContextService.GetFunctionList();
                    }
                    else
                    {
                        throw new Exception("获取用户信息失败");
                    }
                }
                catch
                {
                    LocalStorage.RemoveItem("Authorization");
                    NavigationManager.NavigateTo("login");
                }

                StateHasChanged();
            }
        }
    }


    private void Logout()
    {
        LocalStorage.RemoveItem("Authorization");

        NavigationManager.NavigateTo("login");
    }

}
