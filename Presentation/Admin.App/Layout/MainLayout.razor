@code {
    string leftLayoutStyle = "margin-left:200px";

    RenderFragment subSystemSet =
    @<span class="main-layout-sider__section-title">
        <Icon Class="main-layout-sider__section-icon" Type="control" Theme="IconThemeType.Outline" />
        <span>系统设置</span>
    </span>;

    RenderFragment subOperations =
    @<span class="main-layout-sider__section-title">
        <Icon Class="main-layout-sider__section-icon" Type="tool" Theme="IconThemeType.Outline" />
        <span>运维管理</span>
    </span>;

    RenderFragment subArticle =
    @<span class="main-layout-sider__section-title">
        <Icon Class="main-layout-sider__section-icon" Type="read" Theme="IconThemeType.Outline" />
        <span>资讯管理</span>
    </span>
    ;

    RenderFragment<AntDesign.ReuseTabsPageItem> tabPaneTemplate = context =>
    @<div style="padding-top:0;">
        <div Class="site-layout-background">
            @context.Body
        </div>
    </div>;

    bool collapsed;

    void onCollapse(bool collapsed)
    {
        if (collapsed)
        {
            leftLayoutStyle = "margin-left:80px";

        }
        else
        {
            leftLayoutStyle = "margin-left:200px";

        }

        this.collapsed = collapsed;
    }


    protected override async Task OnInitializedAsync()
    {
        await AuthenticationAsync();
    }

    UserDto user = new();

    List<string> functionList = new();

    bool reuseTabMoreVisible;

    HashSet<int> overflowTabIndexes = [];

    static readonly BindingFlags reuseTabBindingFlags = BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic;

    static readonly PropertyInfo? reuseTabTitleProperty = typeof(AntDesign.ReuseTabsPageItem).GetProperty("Title", reuseTabBindingFlags);

    static readonly PropertyInfo? reuseTabUrlProperty = typeof(AntDesign.ReuseTabsPageItem).GetProperty("Url", reuseTabBindingFlags);

    static readonly FieldInfo? reuseTabUrlField = typeof(AntDesign.ReuseTabsPageItem).GetField("<Url>k__BackingField", reuseTabBindingFlags);


    private async Task AuthenticationAsync()
    {
        var authorization = LocalStorage.GetItemAsString("Authorization");

        if (string.IsNullOrEmpty(authorization))
        {
            NavigationManager.NavigateTo("login");
        }
        else
        {
            JsonWebToken jsonWebToken = new(authorization);

            var expTimeL = Convert.ToInt64(jsonWebToken.GetClaim("exp").Value);

            var expTime = DateTimeOffset.FromUnixTimeSeconds(expTimeL);

            if (expTime < DateTimeOffset.UtcNow)
            {
                NavigationManager.NavigateTo("login");
            }
            else
            {
                try
                {
                    var userRet = await userContextService.GetUser();

                    if (userRet != null)
                    {
                        user = userRet;

                        functionList = await userContextService.GetFunctionList();
                    }
                    else
                    {
                        throw new Exception("获取用户信息失败");
                    }
                }
                catch
                {
                    LocalStorage.RemoveItem("Authorization");
                    NavigationManager.NavigateTo("login");
                }

                StateHasChanged();
            }
        }
    }


    /// <summary>
    /// 获取更多菜单中的复用标签页集合
    /// </summary>
    private IEnumerable<AntDesign.ReuseTabsPageItem> GetReuseTabMenuPages()
    {
        if (overflowTabIndexes.Count == 0)
        {
            return [];
        }

        return ReuseTabsService.Pages
            .Where(page => !page.Ignore)
            .Select((page, index) => new { page, index })
            .Where(item => overflowTabIndexes.Contains(item.index))
            .Select(item => item.page);
    }


    /// <summary>
    /// 渲染更多菜单中的标签标题
    /// </summary>
    private RenderFragment RenderReuseTabTitle(AntDesign.ReuseTabsPageItem page)
    {
        var title = reuseTabTitleProperty?.GetValue(page);

        return builder =>
        {
            switch (title)
            {
                case RenderFragment fragment:
                    fragment(builder);
                    break;
                case string text when !string.IsNullOrWhiteSpace(text):
                    builder.AddContent(0, text);
                    break;
                default:
                    builder.AddContent(0, "未命名标签");
                    break;
            }
        };
    }


    /// <summary>
    /// 获取复用标签页在更多菜单中的样式类
    /// </summary>
    private string GetReuseTabMenuItemClass(AntDesign.ReuseTabsPageItem page)
    {
        return IsCurrentReuseTab(page)
            ? "main-layout-tab-more-menu__item main-layout-tab-more-menu__item--active"
            : "main-layout-tab-more-menu__item";
    }


    /// <summary>
    /// 切换更多标签菜单的显示状态
    /// </summary>
    private async Task ToggleReuseTabMoreMenu()
    {
        if (reuseTabMoreVisible)
        {
            reuseTabMoreVisible = false;
            return;
        }

        var indexes = await JS.InvokeAsync<int[]>("netEngineMainLayout.getOverflowTabIndexes");

        overflowTabIndexes = indexes.ToHashSet();

        reuseTabMoreVisible = overflowTabIndexes.Count > 0;
    }


    /// <summary>
    /// 关闭更多标签菜单
    /// </summary>
    private void CloseReuseTabMoreMenu()
    {
        reuseTabMoreVisible = false;
    }


    /// <summary>
    /// 激活更多菜单中的复用标签页
    /// </summary>
    private void ActivateReuseTab(AntDesign.ReuseTabsPageItem page)
    {
        var pageUrl = GetReuseTabPageUrl(page);

        reuseTabMoreVisible = false;
        overflowTabIndexes.Clear();

        if (!string.IsNullOrWhiteSpace(pageUrl))
        {
            NavigationManager.NavigateTo(pageUrl);
        }
    }


    /// <summary>
    /// 判断复用标签页是否为当前页面
    /// </summary>
    private bool IsCurrentReuseTab(AntDesign.ReuseTabsPageItem page)
    {
        var pageUrl = GetReuseTabPageUrl(page);

        if (string.IsNullOrWhiteSpace(pageUrl))
        {
            return false;
        }

        var currentUrl = "/" + NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimStart('/');

        return string.Equals(currentUrl, pageUrl, StringComparison.OrdinalIgnoreCase);
    }


    /// <summary>
    /// 获取复用标签页的访问地址
    /// </summary>
    private string? GetReuseTabPageUrl(AntDesign.ReuseTabsPageItem page)
    {
        return reuseTabUrlProperty?.GetValue(page) as string ?? reuseTabUrlField?.GetValue(page) as string;
    }


    private void Logout()
    {
        LocalStorage.RemoveItem("Authorization");

        NavigationManager.NavigateTo("login");
    }

}
