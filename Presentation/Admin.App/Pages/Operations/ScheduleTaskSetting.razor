@page "/operations/scheduletasksetting"
@using Application.Model.TaskCenter
@attribute [ReuseTabsPageTitle("定时任务配置")]

<div class="schedule-task-page">
    <div class="schedule-task-page__hero">
        <div>
            <div class="schedule-task-page__eyebrow">Operations</div>
            <h2 class="schedule-task-page__title">定时任务配置台</h2>
            <div class="schedule-task-page__subtitle">统一维护 ScheduleTask 分类任务的启停状态、Cron 表达式与参数 JSON，让日常运维配置、排查和更新都在一个视图内完成</div>

            <div class="schedule-task-page__hero-tools">
                <Button Class="schedule-task-page__hero-button admin-page-button admin-page-button--primary admin-page-button--with-plus" Type="@ButtonType.Primary" @onclick="ShowCreateScheduleTaskAsync"><span class="admin-page-button__content"><span class="admin-page-button__icon" aria-hidden="true">+</span><span class="admin-page-button__text">新增带参任务</span><span class="admin-page-button__spacer" aria-hidden="true"></span></span></Button>
                <Button Class="schedule-task-page__hero-button schedule-task-page__hero-button--light admin-page-button admin-page-button--default" Icon="reload" @onclick="GetTaskSettingListAsync">刷新列表</Button>
            </div>
        </div>

        <div class="schedule-task-page__stats">
            <div class="schedule-task-page__stat-card">
                <span class="schedule-task-page__stat-label">任务总量</span>
                <strong class="schedule-task-page__stat-value">@pageList.Total</strong>
                <span class="schedule-task-page__stat-foot">当前页展示 @(pageList.List?.Count ?? 0) 条配置</span>
            </div>

            <div class="schedule-task-page__stat-card">
                <span class="schedule-task-page__stat-label">当前页启用</span>
                <strong class="schedule-task-page__stat-value">@(pageList.List?.Count(t => t.IsEnable) ?? 0)</strong>
                <span class="schedule-task-page__stat-foot">可直接观察当前页任务启停分布</span>
            </div>

            <div class="schedule-task-page__stat-card">
                <span class="schedule-task-page__stat-label">分页状态</span>
                <strong class="schedule-task-page__stat-value schedule-task-page__stat-value--small">第 @(page) 页 / 每页 @pageSize 条</strong>
                <span class="schedule-task-page__stat-foot">当前分类固定为 ScheduleTask</span>
            </div>
        </div>
    </div>

    <Card Class="schedule-task-page__card schedule-task-page__card--compact" BodyStyle="padding: 14px 14px 10px">
        <div class="schedule-task-page__list-shell">
            <div class="schedule-task-page__table-wrap">
                <Table TItem="TaskSettingDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

                    <ColumnDefinitions>
                        <ActionColumn Title="任务">
                            <div class="schedule-task-page__name-cell">
                                <div class="schedule-task-page__name-title">@context.Name</div>
                            </div>
                        </ActionColumn>

                        <ActionColumn Title="状态">
                            <Tag Class="schedule-task-page__status-tag" Color="@(context.IsEnable ? "#16a34a" : "#94a3b8")">@(context.IsEnable ? "启用中" : "已停用")</Tag>
                        </ActionColumn>

                        <ActionColumn Title="Cron">
                            <div class="schedule-task-page__cron-cell">@(string.IsNullOrWhiteSpace(context.Cron) ? "未配置" : context.Cron)</div>
                        </ActionColumn>

                        <ActionColumn Title="备注">
                            <div class="schedule-task-page__remark-cell">@(string.IsNullOrWhiteSpace(context.Remark) ? "暂无备注说明" : context.Remark)</div>
                        </ActionColumn>

                        <PropertyColumn Property="c => (c.UpdateTime ?? c.CreateTime).LocalDateTime" Format="yyyy-MM-dd HH:mm" Title="更新时间"></PropertyColumn>

                        <ActionColumn Title="操作">
                            <Space>
                                <SpaceItem>
                                    <a class="schedule-task-page__link" @onclick="() => EditTaskSettingAsync(context)">编辑</a>
                                </SpaceItem>
                            </Space>
                        </ActionColumn>
                    </ColumnDefinitions>

                    <PaginationTemplate>
                        <div class="schedule-task-page__pagination">
                            <Pagination Total="@pageList.Total" PageSize="pageSize" Current="page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
                        </div>
                    </PaginationTemplate>

                </Table>
            </div>
        </div>
    </Card>
</div>


<Drawer Closable="true" Width="620" Visible="isShowEditTaskSetting" Title='("任务配置")' OnClose="() => isShowEditTaskSetting = false">
    <Template style="height:100%">
        <div class="schedule-task-drawer">
            <Form Class="schedule-task-drawer__form" Model="@editTaskSetting" Layout="@FormLayout.Vertical" OnFinish="SaveTaskSettingAsync">
                <div class="schedule-task-drawer__section">
                    <div class="schedule-task-drawer__edit-overview">
                        <div class="schedule-task-drawer__edit-main">
                            <div class="schedule-task-drawer__overview-eyebrow">当前任务</div>
                            <div class="schedule-task-drawer__overview-title">@(string.IsNullOrWhiteSpace(taskName) ? "未命名任务" : taskName)</div>
                        </div>

                        <div class="schedule-task-drawer__switch-box">
                            <span class="schedule-task-drawer__switch-label">是否启用</span>
                            <Switch @bind-Value="@editTaskSetting.IsEnable" CheckedChildren="是" UnCheckedChildren="否" />
                        </div>
                    </div>

                    <FormItem Class="schedule-task-drawer__field-item">
                        <div class="schedule-task-drawer__field-label">Cron</div>
                        <Input Placeholder="ScheduleTask 的 Cron 表达式" @bind-Value="@editTaskSetting.Cron" />
                    </FormItem>

                    <FormItem Class="schedule-task-drawer__field-item">
                        <div class="schedule-task-drawer__field-label">参数 JSON</div>
                        <TextArea Placeholder="带参任务参数 JSON" @bind-Value="@editTaskSetting.Parameter" MinRows="6" MaxRows="12" style="width:100%" />
                        <div class="schedule-task-drawer__field-help">建议传入合法 JSON 对象，方便任务执行时直接反序列化使用</div>
                    </FormItem>

                    <FormItem Class="schedule-task-drawer__field-item">
                        <div class="schedule-task-drawer__field-label">备注</div>
                        <TextArea Placeholder="请输入备注" @bind-Value="@editTaskSetting.Remark" MinRows="4" MaxRows="8" style="width:100%" />
                    </FormItem>
                </div>

                <div class="schedule-task-drawer__footer">
                    <Button Class="schedule-task-page__action-button schedule-task-page__action-button--primary admin-page-button admin-page-button--primary" Type="@ButtonType.Primary" HtmlType="submit" Loading="@saveLoading">保存</Button>
                    <Button Class="schedule-task-page__action-button schedule-task-page__action-button--default admin-page-button admin-page-button--default" Type="@ButtonType.Default" @onclick="() => isShowEditTaskSetting = false">取消</Button>
                </div>
            </Form>
        </div>
    </Template>
</Drawer>


<Drawer Closable="true" Width="680" Visible="isShowCreateScheduleTask" Title='("新增带参定时任务")' OnClose="() => isShowCreateScheduleTask = false">
    <Template style="height:100%">
        <div class="schedule-task-drawer">
            <Form Class="schedule-task-drawer__form" Model="@createScheduleTask" Layout="@FormLayout.Vertical" OnFinish="CreateScheduleTaskAsync">
                <div class="schedule-task-drawer__section schedule-task-drawer__section--accent">
                    <div class="schedule-task-drawer__create-head">
                        <div class="schedule-task-drawer__create-main">
                            <FormItem Class="schedule-task-drawer__field-item">
                                <div class="schedule-task-drawer__field-label">任务名称</div>
                                <Select TItem="string" TItemValue="string" @bind-Value="@createScheduleTask.Name" Placeholder="请选择任务名称" Style="width:100%" AllowClear ShowSearch>
                                    @foreach (var name in scheduleTaskNameList)
                                    {
                                        <SelectOption Value="@name" Label="@name"></SelectOption>
                                    }
                                </Select>
                            </FormItem>
                        </div>

                        <div class="schedule-task-drawer__create-side">
                            <FormItem Class="schedule-task-drawer__field-item schedule-task-drawer__field-item--switch">
                                <div class="schedule-task-drawer__switch-panel">
                                    <span class="schedule-task-drawer__switch-label">是否启用</span>
                                    <Switch @bind-Value="@createScheduleTask.IsEnable" CheckedChildren="是" UnCheckedChildren="否" />
                                </div>
                            </FormItem>
                        </div>
                    </div>

                    <FormItem Class="schedule-task-drawer__field-item">
                        <div class="schedule-task-drawer__field-label">Cron</div>
                        <Input Placeholder="Cron 表达式（可选；为空则使用特性默认值）" @bind-Value="@createScheduleTask.Cron" />
                    </FormItem>

                    <FormItem Class="schedule-task-drawer__field-item">
                        <div class="schedule-task-drawer__field-label">参数 JSON</div>
                        <TextArea Placeholder="必填：带参任务参数 JSON" @bind-Value="@createScheduleTask.Parameter" MinRows="8" MaxRows="14" style="width:100%" />
                        <div class="schedule-task-drawer__field-help">建议按对象结构组织字段，便于任务内部直接映射到请求模型</div>
                    </FormItem>

                    <FormItem Class="schedule-task-drawer__field-item">
                        <div class="schedule-task-drawer__field-label">备注</div>
                        <TextArea Placeholder="请输入备注" @bind-Value="@createScheduleTask.Remark" MinRows="4" MaxRows="8" style="width:100%" />
                    </FormItem>
                </div>

                <div class="schedule-task-drawer__footer">
                    <Button Class="schedule-task-page__action-button schedule-task-page__action-button--primary admin-page-button admin-page-button--primary" Type="@ButtonType.Primary" HtmlType="submit" Loading="@createLoading">新增</Button>
                    <Button Class="schedule-task-page__action-button schedule-task-page__action-button--default admin-page-button admin-page-button--default" Type="@ButtonType.Default" @onclick="() => isShowCreateScheduleTask = false">取消</Button>
                </div>
            </Form>
        </div>
    </Template>
</Drawer>

<style>
    .schedule-task-page {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-bottom: 12px;
    }

    .schedule-task-page__hero {
        display: grid;
        grid-template-columns: minmax(280px, 1.35fr) minmax(320px, 1fr);
        gap: 12px;
        padding: 16px 18px;
        border-radius: 22px;
        background:
            radial-gradient(circle at top right, rgba(14, 165, 233, 0.18), transparent 34%),
            radial-gradient(circle at bottom left, rgba(16, 185, 129, 0.14), transparent 30%),
            linear-gradient(135deg, #f8fcff 0%, #edf8ff 46%, #f1fdf7 100%);
        color: #10233f;
        border: 1px solid #e5edf6;
        box-shadow: 0 16px 34px rgba(59, 83, 119, 0.10);
    }

    .schedule-task-page__eyebrow {
        margin-bottom: 8px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #0284c7;
    }

    .schedule-task-page__title {
        margin: 0;
        font-size: 26px;
        line-height: 1.15;
        color: #10233f;
    }

    .schedule-task-page__subtitle {
        margin-top: 6px;
        max-width: 680px;
        font-size: 12px;
        line-height: 1.7;
        color: #526075;
    }

    .schedule-task-page__hero-tools,
    .schedule-task-drawer__footer {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .schedule-task-page__hero-tools {
        margin-top: 12px;
    }

    .schedule-task-page__hero-button,
    .schedule-task-page__action-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        height: 40px;
        padding: 0 18px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 600;
        box-shadow: none;
    }

    .schedule-task-page__hero-button-symbol {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 14px;
        margin-right: 6px;
        font-size: 18px;
        line-height: 1;
        font-weight: 500;
        transform: translateY(-1px);
    }

    .schedule-task-page__hero-button {
        border-color: #7dd3fc;
        background: linear-gradient(180deg, #38bdf8 0%, #0ea5e9 100%);
        box-shadow: 0 10px 18px rgba(14, 165, 233, 0.18);
    }

    .schedule-task-page__hero-button:hover,
    .schedule-task-page__hero-button:focus,
    .schedule-task-page__action-button--primary:hover,
    .schedule-task-page__action-button--primary:focus {
        border-color: #38bdf8;
        background: linear-gradient(180deg, #0ea5e9 0%, #0284c7 100%);
    }

    .schedule-task-page__hero-button--light,
    .schedule-task-page__action-button--default {
        color: #334155;
        border-color: #dbe7f5;
        background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

    .schedule-task-page__hero-button--light:hover,
    .schedule-task-page__hero-button--light:focus,
    .schedule-task-page__action-button--default:hover,
    .schedule-task-page__action-button--default:focus {
        color: #0369a1;
        border-color: #bae6fd;
        background: linear-gradient(180deg, #fafdff 0%, #edf9ff 100%);
    }

    .schedule-task-page__action-button--primary {
        border-color: #7dd3fc;
        background: linear-gradient(180deg, #38bdf8 0%, #0ea5e9 100%);
    }

    .schedule-task-page__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        align-self: stretch;
    }

    .schedule-task-page__stat-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 4px;
        min-height: 86px;
        padding: 10px 12px;
        border-radius: 18px;
        border: 1px solid #e3edf7;
        background: rgba(255, 255, 255, 0.88);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.94);
    }

    .schedule-task-page__stat-card:nth-child(1) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(240, 249, 255, 0.98) 100%);
    }

    .schedule-task-page__stat-card:nth-child(2) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(236, 253, 245, 0.98) 100%);
    }

    .schedule-task-page__stat-card:nth-child(3) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(240, 249, 255, 0.94) 100%);
    }

    .schedule-task-page__stat-label {
        font-size: 11px;
        color: #64748b;
    }

    .schedule-task-page__stat-value {
        font-size: 20px;
        line-height: 1.2;
        color: #10233f;
    }

    .schedule-task-page__stat-value--small {
        font-size: 16px;
    }

    .schedule-task-page__stat-foot {
        font-size: 11px;
        line-height: 1.6;
        color: #64748b;
    }

    .schedule-task-page__card {
        border-radius: 18px;
        border: 1px solid #edf2f7;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    }

    .schedule-task-page__card--compact {
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.05);
    }

    .schedule-task-page__list-shell {
        border: 1px solid #e8eef6;
        border-radius: 18px;
        overflow: hidden;
        background: linear-gradient(180deg, #ffffff 0%, #fcfdff 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

    .schedule-task-page__table-wrap .ant-table {
        background: transparent;
    }

    .schedule-task-page__table-wrap .ant-table-thead > tr > th {
        padding: 14px 12px;
        background: linear-gradient(180deg, #fbfdff 0%, #f0f9ff 100%);
        color: #475569;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.04em;
        border-bottom: 1px solid #dbe7f5;
    }

    .schedule-task-page__table-wrap .ant-table-thead > tr > th::before {
        display: none;
    }

    .schedule-task-page__table-wrap .ant-table-tbody > tr > td {
        padding: 15px 12px;
        color: #1e293b;
        font-size: 13px;
        border-bottom: 1px solid #eef2f7;
        transition: background-color 0.2s ease;
    }

    .schedule-task-page__table-wrap .ant-table-tbody > tr:hover > td {
        background: #f8fcff;
    }

    .schedule-task-page__table-wrap .ant-table-tbody > tr:last-child > td {
        border-bottom: none;
    }

    .schedule-task-page__name-cell {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
    }

    .schedule-task-page__name-title {
        color: #0f172a;
        font-weight: 700;
    }

    .schedule-task-page__status-tag {
        border: none;
        border-radius: 999px;
        padding: 3px 10px;
        font-weight: 700;
    }

    .schedule-task-page__cron-cell {
        display: inline-flex;
        align-items: center;
        max-width: 100%;
        padding: 6px 10px;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #0f172a;
        font-size: 12px;
        font-weight: 700;
        font-family: Consolas, "Courier New", monospace;
        white-space: nowrap;
    }

    .schedule-task-page__remark-cell {
        color: #475569;
        line-height: 1.7;
    }

    .schedule-task-page__link {
        color: #0284c7;
        font-weight: 600;
    }

    .schedule-task-page__pagination {
        margin: 0;
        display: flex;
        justify-content: flex-end;
        padding: 14px 16px 16px 16px;
        border-top: 1px solid #eef4fb;
        background: linear-gradient(180deg, #ffffff 0%, #f9fcff 100%);
    }

    .schedule-task-page__pagination .ant-pagination-total-text {
        color: #64748b;
        font-size: 12px;
    }

    .schedule-task-page__pagination .ant-pagination-item,
    .schedule-task-page__pagination .ant-pagination-prev .ant-pagination-item-link,
    .schedule-task-page__pagination .ant-pagination-next .ant-pagination-item-link,
    .schedule-task-page__pagination .ant-pagination-options-size-changer.ant-select .ant-select-selector,
    .schedule-task-page__pagination .ant-pagination-options-quick-jumper input {
        border-radius: 10px;
        border-color: #dbe7f5;
        box-shadow: none;
    }

    .schedule-task-page__pagination .ant-pagination-item-active {
        background: linear-gradient(180deg, #f0f9ff 0%, #dbeafe 100%);
        border-color: #7dd3fc;
    }

    .schedule-task-page__pagination .ant-pagination-item-active a {
        color: #0369a1;
        font-weight: 700;
    }

    .schedule-task-drawer {
        display: flex;
        flex-direction: column;
        gap: 14px;
        min-height: calc(100vh - 170px);
    }

    .schedule-task-drawer__form {
        display: flex;
        flex-direction: column;
        gap: 14px;
        min-width: 0;
    }

    .schedule-task-drawer__section {
        padding: 18px;
        border-radius: 18px;
        border: 1px solid #e6eef8;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

    .schedule-task-drawer__section--accent {
        background: linear-gradient(180deg, #f8fcff 0%, #f3fbf8 100%);
        border-color: #d7f0e3;
    }

    .schedule-task-drawer__section-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }

    .schedule-task-drawer__section-head--edit {
        justify-content: flex-end;
        margin-bottom: 14px;
    }

    .schedule-task-drawer__edit-overview {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .schedule-task-drawer__edit-overview {
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        padding: 18px;
        border-radius: 18px;
        border: 1px solid #e2edf9;
        background:
            radial-gradient(circle at top right, rgba(56, 189, 248, 0.12), transparent 34%),
            linear-gradient(135deg, #fbfdff 0%, #f3f9ff 52%, #f7fcff 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.96);
    }

    .schedule-task-drawer__edit-main {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
    }

    .schedule-task-drawer__overview-eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #0284c7;
    }

    .schedule-task-drawer__overview-title {
        color: #10233f;
        font-size: 22px;
        line-height: 1.2;
        font-weight: 700;
        word-break: break-word;
    }

    .schedule-task-drawer__section-title {
        font-size: 16px;
        font-weight: 700;
        color: #10233f;
    }

    .schedule-task-drawer__section-desc {
        margin-top: 6px;
        font-size: 13px;
        line-height: 1.7;
        color: #6b7280;
    }

    .schedule-task-drawer__switch-box,
    .schedule-task-drawer__switch-panel {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 44px;
        padding: 10px 12px;
        border-radius: 16px;
        border: 1px solid #dbeafe;
        background: #f8fbff;
        box-sizing: border-box;
    }

    .schedule-task-drawer__switch-label {
        font-size: 12px;
        font-weight: 600;
        color: #334155;
    }

    .schedule-task-drawer__meta-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 16px;
        margin-bottom: 18px;
    }

    .schedule-task-drawer__meta-grid--summary {
        margin-top: 0;
        margin-bottom: 20px;
    }

    .schedule-task-drawer__meta-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-height: 76px;
        padding: 14px 16px;
        border-radius: 16px;
        background: linear-gradient(180deg, #fdfefe 0%, #f8fbff 100%);
        border: 1px solid #eaf1f8;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.96);
    }

    .schedule-task-drawer__meta-grid--summary .schedule-task-drawer__meta-item:nth-child(1) {
        background: linear-gradient(180deg, #ffffff 0%, #f2f9ff 100%);
        border-color: #dbeafe;
    }

    .schedule-task-drawer__meta-grid--summary .schedule-task-drawer__meta-item:nth-child(2) {
        background: linear-gradient(180deg, #ffffff 0%, #f3fbf8 100%);
        border-color: #d7f0e3;
    }

    .schedule-task-drawer__meta-label,
    .schedule-task-drawer__field-label {
        margin-bottom: 6px;
        font-size: 12px;
        font-weight: 600;
        color: #334155;
    }

    .schedule-task-drawer__meta-value {
        color: #10233f;
        font-size: 14px;
        font-weight: 700;
        line-height: 1.6;
