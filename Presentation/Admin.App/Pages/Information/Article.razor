@code {

    async Task UploadImgageAsync(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            try
            {
                var uploadResult = await imageUploadService.UploadImageAsync(file, new ImageUploadRequest
                {
                    Business = "Article",
                    Key = fileKey,
                    Sign = "cover",
                    IsPublicRead = true
                });
                string fileUrl = await JS.InvokeAsync<string>("CreateObjectUrl", uploadResult.FileBytes, uploadResult.ContentType);

                fileList.Add(new UploadFileItem()
                {
                    Id = uploadResult.FileId,
                    FileName = uploadResult.FileName,
                    Url = fileUrl,
                    State = UploadState.Success
                });
            }
            catch (Exception ex)
            {
                Message.Error(file.Name + " 上传失败 " + ex.Message);
            }

            StateHasChanged();
        }

    }


    private Form<EditArticleDto>? _editArticleForm;

    bool isPreviewImg = false;
    string? previewImgUrl;
    long fileKey;
    bool saveLoading = false;
    List<UploadFileItem> fileList = new();

    List<TreeSelectDto>? selectCategoryList;


    List<string> functionList = new();

    override protected async Task OnInitializedAsync()
    {
        functionList = await userContextService.GetFunctionList();
    }

    override protected async Task OnParametersSetAsync()
    {
        var getArticleListTask = GetArticleListAsync();
        var getCategorySelectListTask = GetCategorySelectListAsync();

        await Task.WhenAll(getArticleListTask, getCategorySelectListTask);
    }



    async Task GetCategorySelectListAsync()
    {
        List<CategorySelectDto> parentKVList = new();

        var kvList = await Http.GetFromJsonAsync<List<CategorySelectDto>>("Article/GetCategorySelectList", JsonHelper.DeserializeOpts);

        if (kvList != null)
        {
            parentKVList.AddRange(kvList);

            selectCategoryList = CategoryTreeConvert(parentKVList)!.ToList();
        }

    }

    private IEnumerable<TreeSelectDto>? CategoryTreeConvert(List<CategorySelectDto>? keyValueChildren)
    {
        return keyValueChildren?.Select(t => new TreeSelectDto
        {
            Key = t.Id.ToString()!,
            Title = t.Name!.ToString()!,
            Children = CategoryTreeConvert(t.ChildList),
            IsDisabled = false
        }).ToList();
    }

    bool tableLoading = false;
    int page = 1;
    int pageSize = 10;
    PageListDto<ArticleDto> pageList = new();

    async Task GetArticleListAsync()
    {
        tableLoading = true;
        var retData = await Http.GetFromJsonAsync<PageListDto<ArticleDto>>("Article/GetArticleList?page=" + page + "&pageSize=" + pageSize, JsonHelper.DeserializeOpts);

        if (retData != null)
        {
            pageList = retData;
        }

        tableLoading = false;
        StateHasChanged();
    }

    async Task PageChange(PaginationEventArgs args)
    {
        if (page != args.Page)
        {
            page = args.Page;
        }

        if (pageSize != args.PageSize)
        {
            pageSize = args.PageSize;
        }

        await GetArticleListAsync();
    }
    Func<PaginationTotalContext, string> showTotal = pageList => $"共 {pageList.Total} 条";


    /// <summary>
    /// 获取当前页推荐文章数量
    /// </summary>
    int RecommendArticleCount()
    {
        return pageList.List?.Count(item => item.IsRecommend) ?? 0;
    }


    /// <summary>
    /// 获取当前页显示中的文章数量
    /// </summary>
    int DisplayArticleCount()
    {
        return pageList.List?.Count(item => item.IsDisplay) ?? 0;
    }

    /// <summary>
    /// 获取栏目显示文本
    /// </summary>
    string CategoryText(ArticleDto article)
    {
        return string.IsNullOrWhiteSpace(article.CategoryName) ? "未分配栏目" : article.CategoryName;
    }


    /// <summary>
    /// 获取推荐状态显示文本
    /// </summary>
    string RecommendStatusText(ArticleDto article)
    {
        return article.IsRecommend ? "已推荐" : "普通文章";
    }


    /// <summary>
    /// 获取显示状态文本
    /// </summary>
    string DisplayStatusText(ArticleDto article)
    {
        return article.IsDisplay ? "显示中" : "已隐藏";
    }


    bool isShowEditArticle = false;
    EditArticleDto editArticle = new();
    long articleId;


    async Task EditArticleAsync(ArticleDto? article = null)
    {

        editArticle = new();

        foreach (var item in fileList)
        {
            if (item.Url.StartsWith("blob"))
            {
                JS.InvokeAsync<string>("RevokeObjectUrl", item.Url);
            }
        }

        fileList = new();
        articleId = default;

        if (article != null)
        {

            fileKey = article.Id;

            articleId = article.Id;
            editArticle.CategoryId = article.CategoryId.ToString();

            editArticle.Title = article.Title;
            editArticle.Sort = article.Sort;
            editArticle.ClickCount = article.ClickCount;
            editArticle.Digest = article.Digest;
            editArticle.Content = article.Content;
            editArticle.IsDisplay = article.IsDisplay;
            editArticle.IsRecommend = article.IsRecommend;

            if (article.CoverImageList != null && article.CoverImageList.Any())
            {
                fileList = article.CoverImageList?.Select(t => new UploadFileItem
                {
                    Id = t.Id.ToString(),
                    FileName = "coverImg.jpg",
                    Url = t.Url,
                    State = UploadState.Success
                }).ToList()!;
            }

        }
        else
        {
            fileKey = await Http.GetFromJsonAsync<long>("Base/GetSnowflakeId", JsonHelper.DeserializeOpts);
            editArticle.IsDisplay = true;
            editArticle.Sort = 99;
            editArticle.CategoryId = "";
        }

        var getCategorySelectListTask = GetCategorySelectListAsync();

        isShowEditArticle = true;

        StateHasChanged();

        await Task.WhenAll(getCategorySelectListTask, Task.Delay(200));

        JS.InvokeVoidAsync("InitUeditor", "Content", 370);

    }


    async Task SaveArticleAsync()
    {
        editArticle.Content = await JS.InvokeAsync<string>("GetUeditorContent", "Content");

        if (_editArticleForm!.Validate())
        {

            saveLoading = true;
            try
            {
                if (articleId == default)
                {
                    using var httpResponse = await Http.PostAsJsonAsync<EditArticleDto>("Article/CreateArticle?fileKey=" + fileKey, editArticle, JsonHelper.SerializeOpts);

                    if (httpResponse.IsSuccessStatusCode)
                    {
                        Message.Success("添加成功");
                        isShowEditArticle = false;
                        await GetArticleListAsync();
                    }
                    else if ((int)httpResponse.StatusCode != 400)
                    {
                        Message.Error("添加失败");
                    }
                }
                else
                {
                    using var httpResponse = await Http.PostAsJsonAsync<EditArticleDto>("Article/UpdateArticle?articleId=" + articleId, editArticle, JsonHelper.SerializeOpts);
                    if (httpResponse.IsSuccessStatusCode)
                    {
                        Message.Success("编辑成功");
                        isShowEditArticle = false;
                        await GetArticleListAsync();
                    }
                    else if ((int)httpResponse.StatusCode != 400)
                    {
                        Message.Error("编辑失败");
                    }
                }
            }
            catch (HttpRequestException)
            {
                Message.Error("请求失败，请稍后重试");
            }
            finally
            {
                saveLoading = false;
                StateHasChanged();
            }
        }
    }


    async Task DeleteArticleAsync(long articleId)
    {
        try
        {
            using var httpResponse = await Http.DeleteAsync("Article/DeleteArticle?id=" + articleId);
            if (httpResponse.IsSuccessStatusCode)
            {
                await GetArticleListAsync();
                Message.Success("删除成功");
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("删除失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
    }


    void PreviewImg(UploadFileItem file)
    {
        isPreviewImg = true;
        previewImgUrl = file.Url;
    }

    async Task<bool> DeleteImgAsync(UploadFileItem file)
    {
        try
        {
            using var httpResponse = await Http.DeleteAsync("File/DeleteFile?id=" + file.Id);

            if (httpResponse.IsSuccessStatusCode)
            {
                var retValue = await httpResponse.Content.ReadAsStringAsync();

                if (Convert.ToBoolean(retValue))
                {
                    fileList.Remove(file);

                    return true;
                }
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("删除图片失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }

        return false;
    }

}
