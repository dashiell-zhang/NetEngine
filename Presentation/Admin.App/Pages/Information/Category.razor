@page "/information/category"
@using Application.Model.Site.Article
@attribute [ReuseTabsPageTitle("栏目管理")]

<div class="category-page">
    <div class="category-page__hero">
        <div>
            <div class="category-page__eyebrow">Information Management</div>
            <h2 class="category-page__title">栏目管理工作台</h2>
            <div class="category-page__subtitle">统一维护栏目名称、父级结构和排序规则，让内容结构调整、栏目新增和维护都在一个视图内完成</div>

            @if (functionList.Contains("category-add"))
            {
                <div class="category-page__hero-tools">
                    <Button Class="category-page__action-button category-page__action-button--primary admin-page-button admin-page-button--primary admin-page-button--with-plus" Type="@ButtonType.Primary" @onclick="() => EditCategoryAsync()"><span class="admin-page-button__content"><span class="admin-page-button__icon" aria-hidden="true">+</span><span class="admin-page-button__text">新增栏目</span><span class="admin-page-button__spacer" aria-hidden="true"></span></span></Button>
                </div>
            }
        </div>

        <div class="category-page__stats">
            <div class="category-page__stat-card">
                <span class="category-page__stat-label">栏目总量</span>
                <strong class="category-page__stat-value">@pageList.Total</strong>
                <span class="category-page__stat-foot">当前页展示 @(pageList.List?.Count ?? 0) 个栏目</span>
            </div>

            <div class="category-page__stat-card">
                <span class="category-page__stat-label">当前页顶级</span>
                <strong class="category-page__stat-value">@RootCategoryCount()</strong>
                <span class="category-page__stat-foot">无父级栏目会作为顶层结构直接展示</span>
            </div>

            <div class="category-page__stat-card">
                <span class="category-page__stat-label">默认排序</span>
                <strong class="category-page__stat-value category-page__stat-value--small">@SortBaselineText()</strong>
                <span class="category-page__stat-foot">新增栏目默认采用当前排序基线</span>
            </div>
        </div>
    </div>

    <Card Class="category-page__card category-page__card--compact" BodyStyle="padding: 14px 14px 10px">
        <div class="category-page__list-shell">
            <div class="category-page__section-head">
                <div>
                    <div class="category-page__section-title">栏目列表</div>
                    <div class="category-page__section-desc">查看栏目名称、层级归属和排序值，并在列表中直接完成编辑或删除</div>
                </div>

                <div class="category-page__section-meta">当前加载 @(pageList.List?.Count ?? 0) 条记录</div>
            </div>

            <div class="category-page__table-wrap">
                <Table TItem="CategoryDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

                    <ColumnDefinitions>
                        <ActionColumn Title="栏目">
                            <div class="category-page__name-cell">
                                <div class="category-page__name-title" title="@context.Name">@context.Name</div>
                                <div class="category-page__name-sub" title="@ParentCategoryText(context)">@ParentCategoryText(context)</div>
                            </div>
                        </ActionColumn>

                        <ActionColumn Title="备注">
                            <div class="category-page__remark-cell" title="@RemarkText(context)">@RemarkText(context)</div>
                        </ActionColumn>

                        <ActionColumn Title="排序">
                            <div class="category-page__sort-pill">@context.Sort</div>
                        </ActionColumn>

                        <ActionColumn Title="创建时间">
                            <div class="category-page__time-cell">@context.CreateTime.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                        </ActionColumn>

                        <ActionColumn Title="操作">
                            <Space>
                                @if (functionList.Contains("category-edit"))
                                {
                                    <SpaceItem>
                                        <a class="category-page__link-action" @onclick="() => EditCategoryAsync(context)">编辑</a>
                                    </SpaceItem>
                                }

                                @if (functionList.Contains("category-delete"))
                                {
                                    <SpaceItem>
                                        <Popconfirm Title="确认要删除吗？"
                                                    OnConfirm="_ => DeleteCategoryAsync(context.Id)"
                                                    OkText="Yes"
                                                    CancelText="No">
                                            <a class="category-page__link-action category-page__link-action--danger">删除</a>
                                        </Popconfirm>
                                    </SpaceItem>
                                }
                            </Space>
                        </ActionColumn>
                    </ColumnDefinitions>

                    <PaginationTemplate>
                        <div class="category-page__pagination">
                            <Pagination Total="@pageList.Total" PageSize="pageSize" Current="page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
                        </div>
                    </PaginationTemplate>

                </Table>
            </div>
        </div>
    </Card>
</div>


<Drawer Closable="true" Width="700" Visible="isShowEditCategory" Title='(categoryId == default ? "新增栏目" : "编辑栏目")' OnClose="() => isShowEditCategory = false">
    <Template style="height:100%">
        <div class="category-drawer">
            <Form Class="category-drawer__form" Model="@editCategory" Layout="@FormLayout.Vertical" OnFinish="SaveCategoryAsync">
                <div class="category-drawer__section">
                    <div class="category-drawer__section-title">基础资料</div>

                    <Row Gutter="24">
                        <AntDesign.Col Span="14">
                            <FormItem Class="category-drawer__field-item">
                                <div class="category-drawer__field-label">名称</div>
                                <Input Placeholder="请输入名称" @bind-Value="@context.Name" />
                            </FormItem>
                        </AntDesign.Col>

                        <AntDesign.Col Span="10">
                            <FormItem Class="category-drawer__field-item">
                                <div class="category-drawer__field-label">排序</div>
                                <Input Placeholder="请输入排序值" Type="InputType.Number" @bind-Value="@context.Sort" />
                            </FormItem>
                        </AntDesign.Col>
                    </Row>

                    <FormItem Class="category-drawer__field-item">
                        <div class="category-drawer__field-label">父级栏目</div>
                        <TreeSelect TItem="TreeSelectDto" TItemValue="string" Style="width:100%;" DataSource="selectCategoryList" @bind-Value="@parentId" Placeholder="请选择父级栏目" TreeDefaultExpandAll ChildrenExpression="node => node.DataItem.Children" DisabledExpression="node => node.DataItem.IsDisabled" TitleExpression="node => node.DataItem.Title" KeyExpression="node => node.DataItem.Key" IsLeafExpression="node => node.DataItem.Children == null"></TreeSelect>
                    </FormItem>

                    <FormItem Class="category-drawer__field-item">
                        <div class="category-drawer__field-label">备注</div>
                        <Input Placeholder="请输入备注" @bind-Value="@context.Remark" />
                    </FormItem>
                </div>

                <div class="category-drawer__footer">
                    <Button Class="category-page__action-button category-page__action-button--primary admin-page-button admin-page-button--primary" Type="@ButtonType.Primary" HtmlType="submit" Loading="@saveLoading">保存栏目</Button>
                    <Button Class="category-page__action-button category-page__action-button--default admin-page-button admin-page-button--default" Type="@ButtonType.Default" @onclick="() => isShowEditCategory = false">取消</Button>
                </div>
            </Form>
        </div>
    </Template>
</Drawer>


<style>
