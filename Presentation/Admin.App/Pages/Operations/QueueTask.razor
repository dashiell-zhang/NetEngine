@code {

    List<string> functionList = new();

    override protected async Task OnInitializedAsync()
    {
        functionList = await userContextService.GetFunctionList();
    }

    override protected async Task OnParametersSetAsync()
    {
        await GetQueueTaskListAsync();
    }

    QueueTaskPageRequestDto request = new() { PageSize = 10 };

    bool tableLoading = false;
    PageListDto<QueueTaskDto> pageList = new();

    async Task GetQueueTaskListAsync()
    {
        tableLoading = true;

        var url = StringHelper.ModelToUriParam(request, "Operations/GetQueueTaskList");
        var retData = await Http.GetFromJsonAsync<PageListDto<QueueTaskDto>>(url, JsonHelper.DeserializeOpts);

        if (retData != null)
        {
            pageList = retData;
        }

        tableLoading = false;
        StateHasChanged();
    }

    async Task HandleSearchAsync(EditContext editContext)
    {
        request.Page = 1;
        await GetQueueTaskListAsync();
    }

    async Task HandleReset()
    {
        request = new QueueTaskPageRequestDto { PageSize = request.PageSize };
        await GetQueueTaskListAsync();
    }

    async Task PageChange(PaginationEventArgs args)
    {
        if (request.Page != args.Page)
        {
            request.Page = args.Page;
        }

        if (request.PageSize != args.PageSize)
        {
            request.PageSize = args.PageSize;
        }

        await GetQueueTaskListAsync();
    }

    Func<PaginationTotalContext, string> showTotal = pageList => $"共 {pageList.Total} 条";

    bool isShowDetail = false;
    QueueTaskDto? detail;
    string? detailParameter;
    string? detailCallbackParameter;

    void ViewQueueTask(QueueTaskDto row)
    {
        detail = row;
        detailParameter = row.Parameter;
        detailCallbackParameter = row.CallbackParameter;
        isShowDetail = true;
        StateHasChanged();
    }

    async Task RetryQueueTaskAsync(long id)
    {
        try
        {
            using var httpResponse = await Http.PostAsync("Operations/RetryQueueTask?id=" + id, null);

            if (httpResponse.IsSuccessStatusCode)
            {
                Message.Success("已触发重试");
                await GetQueueTaskListAsync();
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("重试失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
    }


    /// <summary>
    /// 返回结果筛选的展示文案
    /// </summary>
    string SuccessFilterText() => request.IsSuccess switch
    {
        true => "仅成功任务",
        false => "仅未成功",
        _ => "全部结果"
    };


    /// <summary>
    /// 返回时间筛选区间展示文案
    /// </summary>
    string DateRangeText()
    {
        if (request.StartCreateTime == null && request.EndCreateTime == null)
        {
            return "全部时间";
        }

        var startText = request.StartCreateTime?.ToString("MM-dd HH:mm") ?? "不限开始";
        var endText = request.EndCreateTime?.ToString("MM-dd HH:mm") ?? "不限结束";
        return startText + " ~ " + endText;
    }


    /// <summary>
    /// 返回任务状态标签颜色
    /// </summary>
    static string StatusTagColor(int? status) => status switch
    {
        0 => "#94a3b8",
        1 => "#2563eb",
        2 => "#16a34a",
        3 => "#dc2626",
        _ => "#94a3b8"
    };


    /// <summary>
    /// 返回成功结果标签颜色
    /// </summary>
    static string SuccessTagColor(DateTimeOffset? successTime) => successTime == null ? "#f59e0b" : "#16a34a";


    /// <summary>
    /// 返回成功结果展示文案
    /// </summary>
    static string SuccessText(DateTimeOffset? successTime) => successTime == null ? "未成功" : "成功";


    /// <summary>
    /// 返回任务状态展示文案
    /// </summary>
    static string? FormatStatus(int? status) => status switch
    {
        0 => "待领取",
        1 => "执行中",
        2 => "成功",
        3 => "失败",
        null => "-",
        _ => status.ToString()
    };


    /// <summary>
    /// 返回时间展示文案
    /// </summary>
    static string FormatTime(DateTimeOffset? time) => time?.LocalDateTime.ToString("yyyy-MM-dd HH:mm") ?? "-";
}
