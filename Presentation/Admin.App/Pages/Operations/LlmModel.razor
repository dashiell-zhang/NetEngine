@code {

    override protected async Task OnParametersSetAsync()
    {
        await GetLlmModelListAsync();
    }

    LlmModelPageRequestDto request = new() { PageSize = 10 };

    bool tableLoading = false;
    PageListDto<LlmModelDto> pageList = new();

    async Task GetLlmModelListAsync()
    {
        tableLoading = true;

        var url = StringHelper.ModelToUriParam(request, "LlmModel/GetLlmModelList");
        var retData = await Http.GetFromJsonAsync<PageListDto<LlmModelDto>>(url, JsonHelper.DeserializeOpts);

        if (retData != null)
        {
            pageList = retData;
        }

        tableLoading = false;
        StateHasChanged();
    }

    async Task HandleSearchAsync(EditContext editContext)
    {
        request.Page = 1;
        await GetLlmModelListAsync();
    }

    async Task HandleReset()
    {
        request = new LlmModelPageRequestDto { PageSize = request.PageSize };
        await GetLlmModelListAsync();
    }

    async Task PageChange(PaginationEventArgs args)
    {
        if (request.Page != args.Page)
        {
            request.Page = args.Page;
        }

        if (request.PageSize != args.PageSize)
        {
            request.PageSize = args.PageSize;
        }

        await GetLlmModelListAsync();
    }

    Func<PaginationTotalContext, string> showTotal = pageList => $"共 {pageList.Total} 条";

    bool isShowEdit = false;
    bool saveLoading = false;
    long? editId;
    EditLlmModelDto editLlmModel = new();

    static string ProtocolTypeText(int protocolType) => protocolType switch
    {
        0 => "Chat",
        1 => "Responses",
        _ => "未知"
    };

    void EditLlmModel(LlmModelDto? row = null)
    {
        if (row == null)
        {
            editId = null;
            editLlmModel = new EditLlmModelDto { IsEnable = true };
        }
        else
        {
            editId = row.Id;
            editLlmModel = new EditLlmModelDto
            {
                Name = row.Name,
                ModelId = row.ModelId,
                Endpoint = row.Endpoint,
                ProtocolType = row.ProtocolType,
                IsEnable = row.IsEnable,
                Remark = row.Remark
            };
        }

        isShowEdit = true;
    }

    async Task SaveLlmModelAsync()
    {
        if (string.IsNullOrWhiteSpace(editLlmModel.Name))
        {
            Message.Error("名称不可以空");
            return;
        }

        if (string.IsNullOrWhiteSpace(editLlmModel.ModelId))
        {
            Message.Error("模型标识不可以空");
            return;
        }

        if (string.IsNullOrWhiteSpace(editLlmModel.Endpoint))
        {
            Message.Error("端点地址不可以空");
            return;
        }

        if (editId == null && string.IsNullOrWhiteSpace(editLlmModel.ApiKey))
        {
            Message.Error("接口密钥不可以空");
            return;
        }

        saveLoading = true;
        try
        {
            using HttpResponseMessage httpResponse = editId == null
                ? await Http.PostAsJsonAsync("LlmModel/CreateLlmModel", editLlmModel, JsonHelper.SerializeOpts)
                : await Http.PostAsJsonAsync("LlmModel/UpdateLlmModel?id=" + editId.Value, editLlmModel, JsonHelper.SerializeOpts);

            if (httpResponse.IsSuccessStatusCode)
            {
                Message.Success("保存成功");
                isShowEdit = false;
                await GetLlmModelListAsync();
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("保存失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
        finally
        {
            saveLoading = false;
            StateHasChanged();
        }
    }

    async Task DeleteLlmModelAsync(long id)
    {
        try
        {
            using var httpResponse = await Http.DeleteAsync("LlmModel/DeleteLlmModel?id=" + id);

            if (httpResponse.IsSuccessStatusCode)
            {
                Message.Success("删除成功");
                await GetLlmModelListAsync();
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("删除失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
    }
}
