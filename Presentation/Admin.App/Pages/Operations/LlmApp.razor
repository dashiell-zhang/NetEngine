@page "/operations/llmapp"
@using Application.Model.LLM.LlmApp
@using Application.Model.LLM.LlmModel
@using System.Net.Http.Json
@attribute [ReuseTabsPageTitle("LLM应用")]

<div class="llm-app-page">
    <div class="llm-app-page__hero">
        <div>
            <div class="llm-app-page__eyebrow">Operations</div>
            <h2 class="llm-app-page__title">LLM 应用编排台</h2>
            <div class="llm-app-page__subtitle">集中维护应用入口、提示词模板和调试参数，让模型配置、应用配置与联调过程保持在同一视图内完成</div>

            <div class="llm-app-page__hero-tools">
                <Button Class="llm-app-page__hero-button admin-page-button admin-page-button--primary admin-page-button--with-plus" Type="@ButtonType.Primary" @onclick="() => EditLlmApp()"><span class="admin-page-button__content"><span class="admin-page-button__icon" aria-hidden="true">+</span><span class="admin-page-button__text">新增应用</span><span class="admin-page-button__spacer" aria-hidden="true"></span></span></Button>
            </div>
        </div>

        <div class="llm-app-page__stats">
            <div class="llm-app-page__stat-card">
                <span class="llm-app-page__stat-label">应用总量</span>
                <strong class="llm-app-page__stat-value">@pageList.Total</strong>
                <span class="llm-app-page__stat-foot">当前页展示 @(pageList.List?.Count ?? 0) 条记录</span>
            </div>

            <div class="llm-app-page__stat-card">
                <span class="llm-app-page__stat-label">启用筛选</span>
                <strong class="llm-app-page__stat-value llm-app-page__stat-value--small">@(request.IsEnable == null ? "全部应用" : request.IsEnable.Value ? "仅启用" : "仅停用")</strong>
                <span class="llm-app-page__stat-foot">快速聚焦可发布或已停用配置</span>
            </div>

            <div class="llm-app-page__stat-card">
                <span class="llm-app-page__stat-label">检索状态</span>
                <strong class="llm-app-page__stat-value llm-app-page__stat-value--small">@(string.IsNullOrWhiteSpace(request.Keyword) ? "全部应用" : "关键词检索")</strong>
                <span class="llm-app-page__stat-foot">第 @request.Page 页 / 每页 @request.PageSize 条</span>
            </div>
        </div>
    </div>

    <Card Class="llm-app-page__card llm-app-page__card--compact" BodyStyle="padding: 16px 18px">
        <Form Class="llm-app-page__filter-form llm-app-page__filter-form--inline" Model="@request" Layout="@FormLayout.Inline" OnFinish="HandleSearchAsync">
            <FormItem Class="llm-app-page__filter-item llm-app-page__filter-item--keyword">
                <Input @bind-Value="@context.Keyword" Placeholder="Code / 名称 / 备注 模糊检索" AllowClear />
            </FormItem>

            <FormItem Class="llm-app-page__filter-item llm-app-page__filter-item--status">
                <Select TItem="bool?" TItemValue="bool?" @bind-Value="@context.IsEnable" Placeholder="请选择状态" AllowClear>
                    <SelectOption Value="@((bool?)true)" Label="启用"></SelectOption>
                    <SelectOption Value="@((bool?)false)" Label="停用"></SelectOption>
                </Select>
            </FormItem>

            <FormItem Class="llm-app-page__filter-item llm-app-page__filter-item--actions">
                <div class="llm-app-page__filter-actions">
                    <Button Class="llm-app-page__action-button llm-app-page__action-button--primary admin-page-button admin-page-button--primary" Type="@ButtonType.Primary" HtmlType="submit">搜索应用</Button>
                    <Button Class="llm-app-page__action-button llm-app-page__action-button--default admin-page-button admin-page-button--default" OnClick="HandleReset">重置条件</Button>
                </div>
            </FormItem>
        </Form>
    </Card>

    <Card Class="llm-app-page__card llm-app-page__card--compact" BodyStyle="padding: 14px">
        <div class="llm-app-page__list-shell">
            <div class="llm-app-page__table-wrap">
                <Table TItem="LlmAppDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

                    <ColumnDefinitions>
                        <ActionColumn Title="应用">
                            <div class="llm-app-page__app-cell">
                                <div class="llm-app-page__app-code">@context.Code</div>
                                <div class="llm-app-page__app-name">@context.Name</div>
                            </div>
                        </ActionColumn>
                        <PropertyColumn Property="c => c.LlmModelName" Title="模型"></PropertyColumn>
                        <ActionColumn Title="状态">
                            <Tag Class="llm-app-page__status-tag" Color="@EnableStatusColor(context.IsEnable)">@EnableStatusText(context.IsEnable)</Tag>
                        </ActionColumn>
                        <PropertyColumn Property="c => (c.UpdateTime ?? c.CreateTime).LocalDateTime" Format="yyyy-MM-dd HH:mm" Title="更新时间"></PropertyColumn>
                        <ActionColumn Title="操作">
                            <Space>
                                <SpaceItem>
                                    <a class="llm-app-page__link" @onclick="() => EditLlmApp(context)">编辑</a>
                                </SpaceItem>

                                <SpaceItem>
                                    <Popconfirm Title="确认要删除吗？"
                                                OnConfirm="_=>DeleteLlmAppAsync(context.Id)"
                                                OkText="Yes"
                                                CancelText="No">
                                        <a class="llm-app-page__link llm-app-page__link--danger">删除</a>
                                    </Popconfirm>
                                </SpaceItem>
                            </Space>
                        </ActionColumn>
                    </ColumnDefinitions>

                    <PaginationTemplate>
                        <div class="llm-app-page__pagination">
                            <Pagination Total="@pageList.Total" PageSize="@request.PageSize" Current="@request.Page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
                        </div>
                    </PaginationTemplate>

                </Table>
            </div>
        </div>
    </Card>
</div>


<Drawer Closable="true" Width="1480" Visible="isShowEdit" Title='(editId == null ? "新增 LLM 应用" : "编辑 LLM 应用")' OnClose="() => isShowEdit = false">
    <Template style="height:100%">
        <div class="llm-app-drawer">
            <Form Class="llm-app-drawer__form" Model="@editLlmApp" Layout="@FormLayout.Vertical" OnFinish="SaveLlmAppAsync">
                <div class="llm-app-drawer__content">
                    <div class="llm-app-drawer__main">
                        <div class="llm-app-drawer__section">
                            <div class="llm-app-drawer__section-head">
                                <div>
                                    <div class="llm-app-drawer__section-title">基本配置</div>
                                </div>

                                <div class="llm-app-drawer__switch-box">
                                    <span class="llm-app-drawer__switch-label">是否启用</span>
                                    <Switch @bind-Value="@editLlmApp.IsEnable" CheckedChildren="是" UnCheckedChildren="否" />
                                </div>
                            </div>

                            <Row Gutter="24">
                                <AntDesign.Col Span="12">
                                    <FormItem Class="llm-app-drawer__field-item">
                                        <div class="llm-app-drawer__field-label">Code</div>
                                        <Input Placeholder="如: deepseek-chat-default" @bind-Value="@context.Code" />
                                    </FormItem>
                                </AntDesign.Col>

                                <AntDesign.Col Span="12">
                                    <FormItem Class="llm-app-drawer__field-item">
                                        <div class="llm-app-drawer__field-label">名称</div>
                                        <Input Placeholder="请输入名称" @bind-Value="@context.Name" />
                                    </FormItem>
                                </AntDesign.Col>
                            </Row>

                            <Row Gutter="24">
                                <AntDesign.Col Span="24">
                                    <FormItem Class="llm-app-drawer__field-item">
                                        <div class="llm-app-drawer__field-label">模型</div>
                                        <Select TItem="LlmModelSelectDto" TItemValue="long"
                                                DataSource="@modelSelectList"
                                                @bind-Value="@context.LlmModelId"
                                                ValueName="@nameof(LlmModelSelectDto.Id)"
                                                LabelName="@nameof(LlmModelSelectDto.Name)"
                                                Placeholder="请选择模型"
                                                Style="width:100%" />
                                    </FormItem>
                                </AntDesign.Col>
                            </Row>

                            <FormItem Class="llm-app-drawer__textarea-item">
                                <div class="llm-app-drawer__field-label">ExtraBodyJson</div>
                                <TextArea @bind-Value="@context.ExtraBodyJson"
                                          Placeholder='JSON对象，直接透传到请求body根字段，如 {"enable_thinking":true}'
                                          MinRows="4"
                                          MaxRows="10"
                                          style="width:100%" />
                            </FormItem>

                            <FormItem Class="llm-app-drawer__textarea-item">
                                <div class="llm-app-drawer__field-label">备注</div>
                                <TextArea @bind-Value="@context.Remark" MinRows="2" MaxRows="6" style="width:100%" />
                            </FormItem>

                            <FormItem Class="llm-app-drawer__textarea-item">
                                <div class="llm-app-drawer__field-label">SystemPromptTemplate</div>
                                <TextArea @bind-Value="@context.SystemPromptTemplate" MinRows="6" MaxRows="16" style="width:100%" />
                            </FormItem>

                            <FormItem Class="llm-app-drawer__textarea-item">
                                <div class="llm-app-drawer__field-label">PromptTemplate</div>
                                <TextArea @bind-Value="@context.PromptTemplate" MinRows="6" MaxRows="16" style="width:100%" />
                            </FormItem>
                        </div>
                    </div>

                    <div class="llm-app-drawer__side">
                        <div class="llm-app-drawer__section llm-app-drawer__section--sandbox">
                            <div class="llm-app-drawer__section-head">
                                <div>
                                    <div class="llm-app-drawer__section-title">调用测试</div>
                                    <div class="llm-app-drawer__section-desc">识别模板中的占位符并现场填写测试参数，直接验证返回内容是否符合预期</div>
                                </div>
                            </div>

                            @if (PlaceholderInfos.Count != 0)
                            {
                                <div class="llm-app-drawer__placeholder-summary">
                                    检测到占位符：@string.Join("、", PlaceholderInfos.Select(t => t.Display))
                                </div>

                                <Row Gutter="24" class="llm-app-drawer__param-grid">
                                    @foreach (var p in PlaceholderInfos)
                                    {
                                        var paramItem = GetOrCreateTestParamItem(p.Key);
                                        <AntDesign.Col Span="12">
                                            <div class="llm-app-drawer__param-card">
                                                <FormItem>
                                                    <div class="llm-app-drawer__field-label">
                                                        @p.Key
                                                        @if (p.IsRequired)
                                                        {
                                                            <span class="llm-app-drawer__required">*</span>
                                                        }
                                                    </div>
                                                    <Input @bind-Value="@paramItem.Value" Placeholder="@($"请输入 {p.Key}")" />
                                                </FormItem>
                                            </div>
                                        </AntDesign.Col>
                                    }
                                </Row>
                            }
                            else
                            {
                                <div class="llm-app-drawer__placeholder-summary llm-app-drawer__placeholder-summary--empty">
                                    未检测到 {{key}} / {{*key}} 占位符
                                </div>
                            }

                            <div class="llm-app-drawer__test-bar">
                                <Button Class="llm-app-page__action-button llm-app-page__action-button--primary admin-page-button admin-page-button--primary" Type="@ButtonType.Primary" Loading="@testLoading" @onclick="TestCallAsync">调用测试</Button>

                                <div class="llm-app-drawer__test-meta">
                                    @if (!string.IsNullOrWhiteSpace(testResult?.Model))
                                    {
                                        <span class="llm-app-drawer__meta-pill llm-app-drawer__meta-pill--soft">Model: @testResult!.Model</span>
                                    }
                                    @if (testResult?.Usage?.TotalTokens != null)
                                    {
                                        <span class="llm-app-drawer__meta-pill llm-app-drawer__meta-pill--soft">Tokens: @testResult.Usage.TotalTokens</span>
                                    }
                                </div>
                            </div>

                            <div class="llm-app-drawer__result-box">
                                <div class="llm-app-drawer__result-toolbar">
                                    <span class="llm-app-drawer__result-dot"></span>
                                    <span class="llm-app-drawer__result-dot"></span>
                                    <span class="llm-app-drawer__result-dot"></span>
                                    <span class="llm-app-drawer__result-caption">返回结果</span>
                                </div>

                                <TextArea Value="@testResult?.Content" ReadOnly MinRows="6" MaxRows="18" style="width:100%" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="llm-app-drawer__footer">
                    <Button Class="llm-app-page__action-button llm-app-page__action-button--primary admin-page-button admin-page-button--primary" Type="@ButtonType.Primary" HtmlType="submit" Loading="@saveLoading">保存</Button>
                    <Button Class="llm-app-page__action-button llm-app-page__action-button--default admin-page-button admin-page-button--default" Type="@ButtonType.Default" @onclick="() => isShowEdit = false">取消</Button>
                </div>
            </Form>
        </div>
    </Template>
</Drawer>

<style>
    .llm-app-page {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-bottom: 12px;
    }

    .llm-app-page__hero {
        display: grid;
        grid-template-columns: minmax(280px, 1.3fr) minmax(320px, 1fr);
        gap: 12px;
        padding: 16px 18px;
        border-radius: 22px;
        background:
            radial-gradient(circle at top right, rgba(59, 130, 246, 0.18), transparent 36%),
            radial-gradient(circle at bottom left, rgba(45, 212, 191, 0.14), transparent 32%),
            linear-gradient(135deg, #f8fcff 0%, #eef7ff 48%, #f4fffd 100%);
        color: #10233f;
        border: 1px solid #e9eef5;
        box-shadow: 0 16px 34px rgba(59, 83, 119, 0.10);
    }

    .llm-app-page__eyebrow {
        margin-bottom: 8px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #2563eb;
    }

    .llm-app-page__title {
        margin: 0;
        font-size: 26px;
        line-height: 1.15;
        color: #10233f;
    }

    .llm-app-page__subtitle {
        margin-top: 6px;
        max-width: 660px;
        font-size: 11px;
        line-height: 1.6;
        color: #526075;
    }

    .llm-app-page__hero-tools {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    .llm-app-page__hero-button {
        height: 40px;
        padding: 0 18px;
        border-radius: 16px;
        border-color: #93c5fd;
        background: linear-gradient(180deg, #60a5fa 0%, #3b82f6 100%);
        box-shadow: 0 10px 18px rgba(59, 130, 246, 0.20);
    }

    .llm-app-page__hero-button:hover,
    .llm-app-page__hero-button:focus {
        border-color: #60a5fa;
        background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
    }

    .llm-app-page__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        align-self: stretch;
    }

    .llm-app-page__stat-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 4px;
        min-height: 86px;
        padding: 10px 12px;
        border-radius: 18px;
        border: 1px solid #e4edf7;
        background: rgba(255, 255, 255, 0.86);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

    .llm-app-page__stat-card:nth-child(1) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(239, 246, 255, 0.96) 100%);
    }

    .llm-app-page__stat-card:nth-child(2) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(236, 253, 245, 0.96) 100%);
    }

    .llm-app-page__stat-card:nth-child(3) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(245, 243, 255, 0.96) 100%);
    }

    .llm-app-page__stat-label {
        font-size: 11px;
        color: #64748b;
    }

    .llm-app-page__stat-value {
        font-size: 20px;
        line-height: 1.2;
        color: #10233f;
    }

    .llm-app-page__stat-value--small {
        font-size: 16px;
    }

    .llm-app-page__stat-foot {
        font-size: 11px;
        line-height: 1.5;
        color: #64748b;
    }

    .llm-app-page__card {
        border-radius: 18px;
        border: 1px solid #edf2f7;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    }

    .llm-app-page__card--compact {
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.05);
    }

    .llm-app-page__field-label,
    .llm-app-drawer__field-label {
        margin-bottom: 8px;
        font-size: 12px;
        font-weight: 600;
        color: #334155;
    }

    .llm-app-page__filter-form--inline {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .llm-app-page__filter-actions,
    .llm-app-drawer__footer,
    .llm-app-drawer__summary-meta,
    .llm-app-drawer__test-meta,
    .llm-app-drawer__test-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .llm-app-page__filter-form .ant-form-item,
    .llm-app-drawer__form .ant-form-item {
        margin-bottom: 10px;
    }

    .llm-app-drawer__main .ant-form-item {
        margin-bottom: 14px;
    }

    .llm-app-drawer__main .llm-app-drawer__field-item {
        margin-bottom: 16px;
    }

    .llm-app-drawer__main .llm-app-drawer__field-item .llm-app-drawer__field-label {
        margin-bottom: 6px;
    }

    .llm-app-drawer__main .llm-app-drawer__textarea-item {
        margin-bottom: 18px;
    }

    .llm-app-drawer__main .llm-app-drawer__textarea-item .llm-app-drawer__field-label {
        margin-bottom: 4px;
    }

    .llm-app-page__filter-form--inline .ant-form-item {
        margin-right: 0;
        margin-bottom: 0;
    }

    .llm-app-page__filter-item--keyword {
        flex: 1 1 420px;
        min-width: 320px;
    }

    .llm-app-page__filter-item--status {
        flex: 0 0 220px;
    }

    .llm-app-page__filter-item--actions {
        flex: 0 0 auto;
        margin-left: auto;
    }

    .llm-app-page__filter-form .ant-input,
    .llm-app-page__filter-form .ant-input-affix-wrapper,
    .llm-app-page__filter-form .ant-select-single:not(.ant-select-customize-input) .ant-select-selector,
    .llm-app-drawer__form .ant-input,
    .llm-app-drawer__form .ant-input-affix-wrapper,
    .llm-app-drawer__form .ant-select-single:not(.ant-select-customize-input) .ant-select-selector,
    .llm-app-drawer__form .ant-input-textarea-show-count,
    .llm-app-drawer__form .ant-input-textarea textarea {
        border-radius: 16px;
        border-color: #dbe7f5;
        background: #ffffff;
        box-shadow: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .llm-app-page__filter-form .ant-input {
        padding: 0 14px;
    }

    .llm-app-page__filter-form .ant-input-affix-wrapper {
        padding: 0 14px;
        display: flex;
        align-items: center;
    }

    .llm-app-page__filter-form .ant-input-affix-wrapper .ant-input {
        height: auto;
        padding: 0;
        border: none;
        background: transparent;
        box-shadow: none;
    }

    .llm-app-page__filter-form .ant-input,
    .llm-app-page__filter-form .ant-input-affix-wrapper,
    .llm-app-page__filter-form .ant-select-single:not(.ant-select-customize-input) .ant-select-selector,
    .llm-app-drawer__form .ant-input,
    .llm-app-drawer__form .ant-input-affix-wrapper,
    .llm-app-drawer__form .ant-select-single:not(.ant-select-customize-input) .ant-select-selector {
        height: 44px;
        width: 100%;
    }

    .llm-app-page__filter-form .ant-select-single:not(.ant-select-customize-input) .ant-select-selector {
        padding: 0 14px;
        display: flex;
        align-items: center;
    }

    .llm-app-drawer__form .ant-select-single:not(.ant-select-customize-input) .ant-select-selector {
        padding: 0 14px;
        display: flex;
        align-items: center;
    }

    .llm-app-page__filter-form .ant-input,
    .llm-app-page__filter-form .ant-input-affix-wrapper .ant-input,
    .llm-app-page__filter-form .ant-select-selection-item,
    .llm-app-page__filter-form .ant-select-selection-placeholder {
        color: #334155;
        font-size: 13px;
    }

    .llm-app-page__filter-form .ant-select-selection-item,
    .llm-app-page__filter-form .ant-select-selection-placeholder {
        line-height: 42px;
    }

    .llm-app-drawer__form .ant-select-selection-item,
    .llm-app-drawer__form .ant-select-selection-placeholder {
        color: #334155;
        font-size: 13px;
        line-height: 42px;
    }

    .llm-app-page__filter-form .ant-input::placeholder,
    .llm-app-page__filter-form .ant-input-affix-wrapper .ant-input::placeholder {
        color: #94a3b8;
    }

    .llm-app-drawer__form .ant-input-textarea textarea {
        min-height: 120px;
        padding: 14px 16px;
        line-height: 1.75;
    }

    .llm-app-page__filter-form .ant-input,
    .llm-app-page__filter-form .ant-input-affix-wrapper,
    .llm-app-page__filter-form .ant-select-single:not(.ant-select-customize-input) .ant-select-selector,
    .llm-app-drawer__form .ant-input,
    .llm-app-drawer__form .ant-input-affix-wrapper,
    .llm-app-drawer__form .ant-select-single:not(.ant-select-customize-input) .ant-select-selector {
        padding-left: 14px;
        padding-right: 14px;
    }

    .llm-app-page__filter-form .ant-input:hover,
    .llm-app-page__filter-form .ant-input-affix-wrapper:hover,
    .llm-app-page__filter-form .ant-select:not(.ant-select-disabled):hover .ant-select-selector,
    .llm-app-drawer__form .ant-input:hover,
    .llm-app-drawer__form .ant-input-affix-wrapper:hover,
    .llm-app-drawer__form .ant-select:not(.ant-select-disabled):hover .ant-select-selector,
    .llm-app-drawer__form .ant-input-textarea textarea:hover {
        border-color: #bfdbfe;
    }

    .llm-app-page__filter-form .ant-input:focus,
    .llm-app-page__filter-form .ant-input-focused,
