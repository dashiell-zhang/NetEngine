@page "/information/article"
@using Application.Model.Site.Article
@inject ImageUploadService imageUploadService
@attribute [ReuseTabsPageTitle("文章管理")]

<div class="article-page">
    <div class="article-page__hero admin-page-hero--with-actions">
        <div>
            <div class="article-page__eyebrow">Information Management</div>
            <h2 class="article-page__title">文章管理工作台</h2>
            <div class="article-page__subtitle">统一管理文章标题、栏目归属、推荐与显示状态，让内容发布、编辑和维护都在一个视图内快速完成</div>

            @if (functionList.Contains("article-add"))
            {
                <div class="article-page__hero-tools">
                    <Button Class="article-page__action-button article-page__action-button--primary admin-page-button admin-page-button--primary admin-page-button--with-plus" Type="@ButtonType.Primary" OnClick="() => EditArticleAsync()"><span class="admin-page-button__content"><span class="admin-page-button__icon" aria-hidden="true">+</span><span class="admin-page-button__text">添加文章</span><span class="admin-page-button__spacer" aria-hidden="true"></span></span></Button>
                </div>
            }
        </div>

        <div class="article-page__stats">
            <div class="article-page__stat-card">
                <span class="article-page__stat-label">文章总量</span>
                <strong class="article-page__stat-value">@pageList.Total</strong>
                <span class="article-page__stat-foot">当前页加载 @(pageList.List?.Count ?? 0) 篇文章</span>
            </div>

            <div class="article-page__stat-card">
                <span class="article-page__stat-label">当前页推荐</span>
                <strong class="article-page__stat-value">@RecommendArticleCount()</strong>
                <span class="article-page__stat-foot">推荐内容可在首页或重点区位优先展示</span>
            </div>

            <div class="article-page__stat-card">
                <span class="article-page__stat-label">当前页显示中</span>
                <strong class="article-page__stat-value article-page__stat-value--small">@DisplayArticleCount()</strong>
                <span class="article-page__stat-foot">已显示文章会在前台内容列表中对外可见</span>
            </div>
        </div>
    </div>

    <Card Class="article-page__card article-page__card--compact" BodyStyle="padding: 14px 14px 10px">
        <div class="article-page__list-shell admin-page-list-shell">
            <div class="article-page__table-wrap">
                <Table TItem="ArticleDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

                    <ColumnDefinitions>
                        <ActionColumn Title="标题">
                            <div class="article-page__title-cell">
                                <div class="article-page__title-main" title="@context.Title">@context.Title</div>
                            </div>
                        </ActionColumn>

                        <ActionColumn Title="类别">
                            <div class="article-page__category-pill" title="@CategoryText(context)">@CategoryText(context)</div>
                        </ActionColumn>

                        <ActionColumn Title="推荐状态">
                            <div class="article-page__state-badge @(context.IsRecommend ? "article-page__state-badge--blue" : "article-page__state-badge--plain")">@RecommendStatusText(context)</div>
                        </ActionColumn>

                        <ActionColumn Title="显示状态">
                            <div class="article-page__state-badge @(context.IsDisplay ? "article-page__state-badge--green" : "article-page__state-badge--warn")">@DisplayStatusText(context)</div>
                        </ActionColumn>

                        <ActionColumn Title="点击量">
                            <div class="article-page__click-pill">@context.ClickCount</div>
                        </ActionColumn>

                        <ActionColumn Title="创建时间">
                            <div class="article-page__time-cell">@context.CreateTime.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                        </ActionColumn>

                        <ActionColumn Title="操作">
                            <Space>

                                @if (functionList.Contains("article-edit"))
                                {
                                    <SpaceItem>
                                        <a class="article-page__link-action" @onclick="() => EditArticleAsync(context)">编辑</a>
                                    </SpaceItem>
                                }

                                @if (functionList.Contains("article-delete"))
                                {
                                    <SpaceItem>
                                        <Popconfirm Title="确认要删除吗？"
                                                    OnConfirm="_=>DeleteArticleAsync(context.Id)"
                                                    OkText="Yes"
                                                    CancelText="No">
                                            <a class="article-page__link-action article-page__link-action--danger">删除</a>
                                        </Popconfirm>

                                    </SpaceItem>
                                }

                            </Space>
                        </ActionColumn>
                    </ColumnDefinitions>

                    <PaginationTemplate>
                        <div class="article-page__pagination admin-page-list-pagination">
                            <Pagination Total="@pageList.Total" PageSize="pageSize" Current="page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
                        </div>
                    </PaginationTemplate>

                </Table>
            </div>
        </div>
    </Card>
</div>


@{
    RenderFragment editFooter = @<Template>
        <div class="article-editor__footer-actions">
            <Button Class="article-page__action-button article-page__action-button--primary admin-page-button admin-page-button--primary" OnClick="SaveArticleAsync" Type="@ButtonType.Primary" Loading="@saveLoading">保存文章</Button>
            <Button Class="article-page__action-button article-page__action-button--default admin-page-button admin-page-button--default" OnClick="() => isShowEditArticle = false" @key="@("back")">取消</Button>
        </div>
    </Template>;
}


<Modal Title='@(articleId == default ? "新增文章" : "编辑文章")' Width="1440" MaxBodyHeight="@("calc(100vh - 150px)")" Visible="@isShowEditArticle" Class="article-editor-modal" Centered="true" Maximizable="true" OnCancel="() => isShowEditArticle = false" Footer="@editFooter">

    <div class="article-editor">
    <Form @ref="@_editArticleForm" Model="@editArticle" Layout="@FormLayout.Vertical" Class="ueditorBody article-editor__form">
        <div class="article-editor__workspace">
            <div class="article-editor__main-column">
                <div class="article-editor__panel">
                    <div class="article-editor__panel-title">基础资料</div>

                    <div class="article-editor__info-grid">
                        <FormItem Label="所属栏目" Class="article-editor__field-item">
                            <TreeSelect TItem="TreeSelectDto" TItemValue="string" Style="width:100%;" DataSource="selectCategoryList" @bind-Value="@context.CategoryId" Placeholder="请选择所属栏目" TreeDefaultExpandAll ChildrenExpression="node => node.DataItem.Children" DisabledExpression="node => node.DataItem.IsDisabled" TitleExpression="node => node.DataItem.Title" KeyExpression="node => node.DataItem.Key" IsLeafExpression="node => node.DataItem.Children == null"></TreeSelect>
                        </FormItem>

                        <FormItem Label="标题" Class="article-editor__field-item article-editor__field-item--wide">
                            <Input Placeholder="请输入标题" @bind-Value="@context.Title" style="width:100%;" />
                        </FormItem>
                    </div>

                    <FormItem Label="内容" Class="article-editor__field-item article-editor__content-item">
                        <TextArea Id="Content" @bind-Value="@context.Content" />
                    </FormItem>
                </div>
            </div>

            <div class="article-editor__side-column">
                <div class="article-editor__settings-card article-editor__panel">
                    <div class="article-editor__panel-title">发布设置</div>

                    <div class="article-editor__toggle-stack">
                        <div class="article-editor__toggle-card">
                            <div class="article-editor__toggle-copy">
                                <span class="article-editor__toggle-title">是否显示</span>
                            </div>
                            <Switch @bind-Value="@context.IsDisplay" CheckedChildren="是" UnCheckedChildren="否" />
                        </div>

                        <div class="article-editor__toggle-card">
                            <div class="article-editor__toggle-copy">
                                <span class="article-editor__toggle-title">是否推荐</span>
                            </div>
                            <Switch @bind-Value="@context.IsRecommend" CheckedChildren="是" UnCheckedChildren="否" />
                        </div>
                    </div>

                    <div class="article-editor__mini-grid">
                        <FormItem Label="排序" Class="article-editor__field-item">
                            <Input Placeholder="请输入排序值" Type="InputType.Number" @bind-Value="@context.Sort" style="width:100%;" />
                        </FormItem>

                        <FormItem Label="点击量" Class="article-editor__field-item">
                            <Input Placeholder="请输入点击量" Type="InputType.Number" @bind-Value="@context.ClickCount" style="width:100%;" />
                        </FormItem>
                    </div>
                </div>

                <div class="article-editor__panel article-editor__cover-panel">
                    <div class="article-editor__panel-title">摘要与封面</div>

                    <FormItem Label="摘要" Class="article-editor__field-item article-editor__summary-item">
                        <TextArea ShowCount MaxLength=255 Placeholder="不填写则自动截取内容前255字符" @bind-Value="@context.Digest" MinRows="3" MaxRows="4" style="width:100%;min-height:78px" />
                    </FormItem>

                    <FormItem Class="article-editor__field-item article-editor__upload-item">
                        <InputFile id="fileInput" OnChange="@UploadImgageAsync" hidden multiple accept=".png,.jpg" />
                        <Upload Name="files">
                            <label class="ant-btn article-editor__upload-trigger" for="fileInput">
                                <Icon Type="upload" />
                                上传图片
                            </label>
                        </Upload>

                        <Upload FileList="fileList" ListType="UploadListType.PictureCard" OnPreview="(file) => PreviewImg(file)" OnRemove=" (file)=> DeleteImgAsync(file)" ShowButton=false style="margin-top:12px"></Upload>

                        <Image PreviewSrc="@previewImgUrl" Style="display: none;" @bind-PreviewVisible="isPreviewImg" />
                    </FormItem>
                </div>
            </div>
        </div>

    </Form>
</div>
</Modal>


<style>
    .article-page {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-bottom: 12px;
    }

    .article-page__hero {
        display: grid;
        grid-template-columns: minmax(280px, 1.35fr) minmax(320px, 1fr);
        gap: 12px;
        padding: 15px 16px;
        border-radius: 20px;
        background:
            radial-gradient(circle at top right, rgba(37, 99, 235, 0.16), transparent 35%),
            radial-gradient(circle at bottom left, rgba(45, 212, 191, 0.14), transparent 30%),
            linear-gradient(135deg, #f8fbff 0%, #eef7ff 48%, #f5fffc 100%);
        color: #10233f;
        border: 1px solid #dfebf8;
        box-shadow: 0 16px 34px rgba(59, 83, 119, 0.10);
    }

    .article-page__eyebrow {
        margin-bottom: 6px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #2563eb;
    }

    .article-page__title {
        margin: 0;
        font-size: 24px;
        line-height: 1.2;
        color: #10233f;
    }

    .article-page__subtitle {
        margin-top: 6px;
        max-width: 640px;
        font-size: 11px;
        line-height: 1.6;
        color: #526075;
    }

    .article-page__hero-tools {
        margin-top: 14px;
    }

    .article-page__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        align-self: stretch;
    }

    .article-page__stat-card {
        display: flex;
        flex-direction: column;
        gap: 6px;
        justify-content: space-between;
        min-height: 88px;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid #dbe9f8;
        background: rgba(255, 255, 255, 0.86);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.90);
    }

    .article-page__stat-card:nth-child(1) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(239, 246, 255, 0.96) 100%);
    }

    .article-page__stat-card:nth-child(2) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(240, 253, 250, 0.96) 100%);
    }

    .article-page__stat-card:nth-child(3) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(239, 248, 255, 0.92) 100%);
    }

    .article-page__stat-label {
        font-size: 11px;
        font-weight: 600;
        color: #5a6b82;
    }

    .article-page__stat-value {
        font-size: 24px;
        line-height: 1;
        color: #10233f;
    }

    .article-page__stat-value--small {
        font-size: 24px;
    }

    .article-page__stat-foot {
        font-size: 11px;
        color: #6c7a8f;
    }

    .article-page__card {
        border: 1px solid #e6edf5;
        border-radius: 20px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        box-shadow: 0 12px 28px rgba(59, 83, 119, 0.06);
    }

    .article-page__card--compact {
        overflow: hidden;
    }

    .article-page__list-shell {
        display: flex;
        flex-direction: column;
    }

    .article-page__table-wrap {
        overflow: hidden;
        border-radius: 16px;
    }

    .article-page__table-wrap .ant-table {
        background: transparent;
    }

    .article-page__table-wrap .ant-table-thead > tr > th {
        padding: 14px 16px;
        font-size: 12px;
        font-weight: 700;
        color: #42556d;
        background: #f7faff;
        border-bottom: 1px solid #e9eff6;
    }

    .article-page__table-wrap .ant-table-thead > tr > th::before {
