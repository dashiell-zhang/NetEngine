    }

    .article-page__table-wrap .ant-table-tbody > tr:hover > td {
        background: #f8fbff;
    }

    .article-page__table-wrap .ant-table-tbody > tr:last-child > td {
        border-bottom: none;
    }

    .article-page__title-cell {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
        max-width: 360px;
    }

    .article-page__title-main,
    .article-page__time-cell {
        font-size: 14px;
        font-weight: 600;
        color: #12263f;
    }

    .article-page__title-main {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .article-page__category-pill,
    .article-page__click-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        white-space: nowrap;
        font-size: 12px;
        font-weight: 700;
    }

    .article-page__category-pill {
        color: #1d4f91;
        background: #eef6ff;
    }

    .article-page__click-pill {
        min-width: 52px;
        color: #1d4f91;
        background: #eef6ff;
    }

    .article-page__state-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .article-page__state-badge--blue {
        background: #eef6ff;
        color: #1d4ed8;
    }

    .article-page__state-badge--green {
        background: #ecfdf3;
        color: #15803d;
    }

    .article-page__state-badge--warn {
        background: #fff4e8;
        color: #c2410c;
    }

    .article-page__state-badge--plain {
        background: #f4f7fb;
        color: #64748b;
    }

    .article-page__link-action {
        font-weight: 600;
        color: #2563eb;
    }

    .article-page__link-action--danger {
        color: #dc2626;
    }

    .article-page__pagination {
        margin: 0;
        display: flex;
        justify-content: flex-end;
        padding: 14px 16px 16px 16px;
        border-top: 1px solid #eef4fb;
        background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
    }

    .article-page__pagination .ant-pagination-total-text {
        color: #64748b;
        font-size: 12px;
    }

    .article-page__pagination .ant-pagination-item,
    .article-page__pagination .ant-pagination-prev .ant-pagination-item-link,
    .article-page__pagination .ant-pagination-next .ant-pagination-item-link,
    .article-page__pagination .ant-pagination-options-size-changer.ant-select .ant-select-selector,
    .article-page__pagination .ant-pagination-options-quick-jumper input {
        border-radius: 10px;
        border-color: #dbe7f5;
        box-shadow: none;
    }

    .article-page__pagination .ant-pagination-item-active {
        background: linear-gradient(180deg, #eef6ff 0%, #dbeafe 100%);
        border-color: #93c5fd;
    }

    .article-page__pagination .ant-pagination-item-active a {
        color: #1d4ed8;
        font-weight: 700;
    }

    .article-editor {
        padding: 6px 0 0;
    }

    .article-editor-modal .ant-modal-body {
        overflow-y: auto !important;
        overflow-x: hidden !important;
    }

    .article-editor__footer-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 12px;
        min-height: 38px;
    }

    .article-editor__form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .article-editor__workspace {
        display: grid;
        grid-template-columns: minmax(0, 1.9fr) minmax(280px, 0.68fr);
        gap: 12px;
        align-items: start;
    }

    .article-editor__main-column,
    .article-editor__side-column {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .article-editor__panel {
        padding: 14px 14px 10px;
        border-radius: 18px;
        border: 1px solid #e8eef5;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    }

    .article-editor__panel--wide {
        padding-bottom: 12px;
    }

    .article-editor__panel-title {
        margin-bottom: 6px;
        font-size: 16px;
        font-weight: 700;
        color: #163250;
    }

    .article-editor__panel-desc {
        margin-bottom: 10px;
        font-size: 12px;
        line-height: 1.6;
        color: #708095;
    }

    .article-editor__field-item {
        margin-bottom: 12px;
    }

    .article-editor__field-item--wide {
        grid-column: span 2;
    }

    .article-editor__info-grid,
    .article-editor__mini-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0 16px;
    }

    .article-editor__summary-item {
        margin-bottom: 8px;
    }

    .article-editor__settings-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .article-editor__settings-desc {
        margin-bottom: 10px;
        font-size: 12px;
        line-height: 1.6;
        color: #708095;
    }

    .article-editor__toggle-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 10px;
    }

    .article-editor__toggle-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 10px 12px;
        border-radius: 14px;
        border: 1px solid #e6edf6;
        background: rgba(255, 255, 255, 0.78);
    }

    .article-editor__toggle-copy {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
    }

    .article-editor__toggle-title {
        font-size: 13px;
        font-weight: 700;
        color: #163250;
    }

    .article-editor__toggle-note {
        font-size: 12px;
        line-height: 1.5;
        color: #708095;
    }

    .article-editor .ant-input,
    .article-editor .ant-input-affix-wrapper,
    .article-editor .ant-select-single:not(.ant-select-customize-input) .ant-select-selector,
