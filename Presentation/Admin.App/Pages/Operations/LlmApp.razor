@code {

    List<string> functionList = new();

    override protected async Task OnInitializedAsync()
    {
        functionList = await userContextService.GetFunctionList();
    }

    override protected async Task OnParametersSetAsync()
    {
        await GetLlmAppListAsync();
    }

    LlmAppPageRequestDto request = new() { PageSize = 10 };

    bool tableLoading = false;
    PageListDto<LlmAppDto> pageList = new();

    List<LlmModelSelectDto> modelSelectList = [];

    async Task GetLlmAppListAsync()
    {
        tableLoading = true;

        var url = StringHelper.ModelToUriParam(request, "Operations/GetLlmAppList");
        var retData = await Http.GetFromJsonAsync<PageListDto<LlmAppDto>>(url, JsonHelper.DeserializeOpts);

        if (retData != null)
        {
            pageList = retData;
        }

        tableLoading = false;
        StateHasChanged();
    }

    async Task GetModelSelectListAsync()
    {
        var retData = await Http.GetFromJsonAsync<List<LlmModelSelectDto>>("LlmModel/GetLlmModelSelect", JsonHelper.DeserializeOpts);
        if (retData != null)
        {
            modelSelectList = retData;
        }
    }

    async Task HandleSearchAsync(EditContext editContext)
    {
        request.Page = 1;
        await GetLlmAppListAsync();
    }

    async Task HandleReset()
    {
        request = new LlmAppPageRequestDto { PageSize = request.PageSize };
        await GetLlmAppListAsync();
    }

    async Task PageChange(PaginationEventArgs args)
    {
        if (request.Page != args.Page)
        {
            request.Page = args.Page;
        }

        if (request.PageSize != args.PageSize)
        {
            request.PageSize = args.PageSize;
        }

        await GetLlmAppListAsync();
    }

    Func<PaginationTotalContext, string> showTotal = pageList => $"共 {pageList.Total} 条";


    /// <summary>
    /// 返回启用状态展示文案
    /// </summary>
    static string EnableStatusText(bool isEnable) => isEnable ? "启用中" : "已停用";


    /// <summary>
    /// 返回启用状态标签颜色
    /// </summary>
    static string EnableStatusColor(bool isEnable) => isEnable ? "#3b82f6" : "#94a3b8";

    bool isShowEdit = false;
    bool saveLoading = false;
    bool testLoading = false;
    long? editId;
    EditLlmAppDto editLlmApp = new();
    TestLlmAppResultDto? testResult;
    List<TestParamItem> testParamItems = [];

    static readonly System.Text.RegularExpressions.Regex PlaceholderRegex = new(@"\{\{\s*(?<required>\*)?\s*(?<key>[^{}\s]+)\s*\}\}", System.Text.RegularExpressions.RegexOptions.Compiled);

    List<PlaceholderInfo> PlaceholderInfos
    {
        get
        {
            List<PlaceholderInfo> list = [];
            Dictionary<string, int> indexByKey = new(StringComparer.OrdinalIgnoreCase);

            void Collect(string? template)
            {
                if (string.IsNullOrWhiteSpace(template))
                {
                    return;
                }

                foreach (System.Text.RegularExpressions.Match m in PlaceholderRegex.Matches(template))
                {
                    var key = m.Groups["key"].Value?.Trim();
                    var isRequired = m.Groups["required"].Success;

                    if (!string.IsNullOrWhiteSpace(key))
                    {
                        if (indexByKey.TryGetValue(key, out var index))
                        {
                            var existing = list[index];
                            if (!existing.IsRequired && isRequired)
                            {
                                list[index] = new PlaceholderInfo(existing.Key, true);
                            }
                        }
                        else
                        {
                            indexByKey[key] = list.Count;
                            list.Add(new PlaceholderInfo(key, isRequired));
                        }
                    }
                }
            }

            Collect(editLlmApp.SystemPromptTemplate);
            Collect(editLlmApp.PromptTemplate);

            return list;
        }
    }

    TestParamItem GetOrCreateTestParamItem(string key)
    {
        var item = testParamItems.FirstOrDefault(t => t.Key.Equals(key, StringComparison.OrdinalIgnoreCase));
        if (item == null)
        {
            item = new TestParamItem { Key = key, Value = string.Empty };
            testParamItems.Add(item);
        }
        return item;
    }

    async Task EditLlmApp(LlmAppDto? row = null)
    {
        if (row == null)
        {
            editId = null;
            editLlmApp = new EditLlmAppDto { IsEnable = true };
        }
        else
        {
            editId = row.Id;
            editLlmApp = new EditLlmAppDto
            {
                Code = row.Code,
                Name = row.Name,
                LlmModelId = row.LlmModelId,
                SystemPromptTemplate = row.SystemPromptTemplate,
                PromptTemplate = row.PromptTemplate,
                ExtraBodyJson = row.ExtraBodyJson,
                IsEnable = row.IsEnable,
                Remark = row.Remark
            };
        }

        testResult = null;
        testParamItems = [];

        await GetModelSelectListAsync();
        await Task.Delay(150);
        isShowEdit = true;
        StateHasChanged();
    }

    async Task SaveLlmAppAsync()
    {
        if (string.IsNullOrWhiteSpace(editLlmApp.Code))
        {
            Message.Error("Code 不可以空");
            return;
        }

        if (string.IsNullOrWhiteSpace(editLlmApp.Name))
        {
            Message.Error("名称不可以空");
            return;
        }

        if (editLlmApp.LlmModelId == 0)
        {
            Message.Error("请选择模型");
            return;
        }

        if (string.IsNullOrWhiteSpace(editLlmApp.PromptTemplate))
        {
            Message.Error("PromptTemplate 不可以空");
            return;
        }

        saveLoading = true;
        try
        {
            using HttpResponseMessage httpResponse = editId == null
                ? await Http.PostAsJsonAsync("Operations/CreateLlmApp", editLlmApp, JsonHelper.SerializeOpts)
                : await Http.PostAsJsonAsync("Operations/UpdateLlmApp?id=" + editId.Value, editLlmApp, JsonHelper.SerializeOpts);

            if (httpResponse.IsSuccessStatusCode)
            {
                Message.Success("保存成功");
                isShowEdit = false;
                await GetLlmAppListAsync();
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("保存失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
        finally
        {
            saveLoading = false;
            StateHasChanged();
        }
    }

    async Task TestCallAsync()
    {
        if (editLlmApp.LlmModelId == 0)
        {
            Message.Error("请先选择模型");
            return;
        }

        testLoading = true;
        testResult = null;

        var missing = PlaceholderInfos
            .Where(t => t.IsRequired)
            .Select(t => t.Key)
            .Where(k => string.IsNullOrWhiteSpace(GetOrCreateTestParamItem(k).Value))
            .ToList();

        if (missing.Count != 0)
        {
            Message.Error("必传参数未填写: " + string.Join("、", missing));
            testLoading = false;
            return;
        }

        Dictionary<string, System.Text.Json.Nodes.JsonNode>? extraBody;
        try
        {
            extraBody = ParseExtraBody(editLlmApp.ExtraBodyJson);
        }
        catch (Exception ex)
        {
            Message.Error(ex.Message);
            testLoading = false;
            return;
        }

        var req = new TestLlmAppRequestDto
        {
            LlmModelId = editLlmApp.LlmModelId,
            SystemPromptTemplate = editLlmApp.SystemPromptTemplate,
            PromptTemplate = editLlmApp.PromptTemplate ?? string.Empty,
            ExtraBody = extraBody,
            Parameters = PlaceholderInfos.ToDictionary(k => k.Key, k => GetOrCreateTestParamItem(k.Key).Value, StringComparer.OrdinalIgnoreCase)
        };

        try
        {
            using var httpResponse = await Http.PostAsJsonAsync("Operations/TestLlmApp", req, JsonHelper.SerializeOpts);

            if (httpResponse.IsSuccessStatusCode)
            {
                testResult = await httpResponse.Content.ReadFromJsonAsync<TestLlmAppResultDto>(JsonHelper.DeserializeOpts);
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("调用失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
        finally
        {
            testLoading = false;
            StateHasChanged();
        }
    }

    record PlaceholderInfo(string Key, bool IsRequired)
    {
        public string Display => IsRequired ? Key + "*" : Key;
    }

    class TestParamItem
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    static Dictionary<string, System.Text.Json.Nodes.JsonNode>? ParseExtraBody(string? extraBodyJson)
    {
        if (string.IsNullOrWhiteSpace(extraBodyJson))
        {
            return null;
        }

        try
        {
            var node = System.Text.Json.Nodes.JsonNode.Parse(extraBodyJson);
            if (node is not System.Text.Json.Nodes.JsonObject obj)
            {
                throw new Exception("not object");
            }

            Dictionary<string, System.Text.Json.Nodes.JsonNode> dict = new(StringComparer.Ordinal);
            foreach (var kv in obj)
            {
                if (!string.IsNullOrWhiteSpace(kv.Key) && kv.Value != null)
                {
                    dict[kv.Key] = kv.Value;
                }
            }

            return dict.Count == 0 ? null : dict;
        }
        catch
        {
            throw new Exception("ExtraBodyJson 不是合法的 JSON 对象");
        }
    }

    async Task DeleteLlmAppAsync(long id)
    {
        try
        {
            using var httpResponse = await Http.DeleteAsync("Operations/DeleteLlmApp?id=" + id);

            if (httpResponse.IsSuccessStatusCode)
            {
                Message.Success("删除成功");
                await GetLlmAppListAsync();
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("删除失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
    }
}
