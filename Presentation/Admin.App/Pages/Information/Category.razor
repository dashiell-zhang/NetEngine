</style>


@code {

    string parentId = "0";

    List<TreeSelectDto>? selectCategoryList = new();

    List<string> functionList = new();

    override protected async Task OnInitializedAsync()
    {
        functionList = await userContextService.GetFunctionList();
    }

    override protected async Task OnParametersSetAsync()
    {
        var getCategoryListTask = GetCategoryListAsync();
        var getCategorySelectListTask = GetCategorySelectListAsync();

        await Task.WhenAll(getCategoryListTask, getCategorySelectListTask);
    }


    async Task GetCategorySelectListAsync()
    {
        List<CategorySelectDto> parentKVList = new();


        parentKVList.Add(new CategorySelectDto { Id = 0, Name = "无父级栏目" });



        var kvList = await Http.GetFromJsonAsync<List<CategorySelectDto>>("Article/GetCategorySelectList", JsonHelper.DeserializeOpts);

        if (kvList != null)
        {
            parentKVList.AddRange(kvList);

            selectCategoryList = CategoryTreeConvert(parentKVList)!.ToList();
        }

    }

    private IEnumerable<TreeSelectDto>? CategoryTreeConvert(List<CategorySelectDto>? keyValueChildren)
    {
        return keyValueChildren?.Select(t => new TreeSelectDto
        {
            Key = t.Id.ToString()!,
            Title = t.Name!.ToString()!,
            Children = CategoryTreeConvert(t.ChildList),
            IsDisabled = (categoryId == t.Id && categoryId != 0)
        }).ToList();
    }

    bool saveLoading = false;


    bool tableLoading = false;
    int page = 1;
    int pageSize = 10;
    PageListDto<CategoryDto> pageList = new();

    async Task GetCategoryListAsync()
    {
        tableLoading = true;
        var retData = await Http.GetFromJsonAsync<PageListDto<CategoryDto>>("Article/GetCategoryList?page=" + page + "&pageSize=" + pageSize, JsonHelper.DeserializeOpts);

        if (retData != null)
        {
            pageList = retData;
        }

        tableLoading = false;
        StateHasChanged();
    }

    async Task PageChange(PaginationEventArgs args)
    {
        if (page != args.Page)
        {
            page = args.Page;
        }

        if (pageSize != args.PageSize)
        {
            pageSize = args.PageSize;
        }

        await GetCategoryListAsync();
    }

    Func<PaginationTotalContext, string> showTotal = pageList => $"共 {pageList.Total} 条";


    bool isShowEditCategory = false;
    EditCategoryDto editCategory = new();
    long categoryId;


    async Task EditCategoryAsync(CategoryDto? category = null)
    {
        editCategory = new();
        categoryId = default;

        if (category != null)
        {
            categoryId = category.Id;
            editCategory.Name = category.Name;
            editCategory.Remark = category.Remark;
            editCategory.Sort = category.Sort;

            if (category.ParentId == null)
            {
                editCategory.ParentId = 0;
            }
            else
            {
                editCategory.ParentId = category.ParentId;
            }

            parentId = editCategory.ParentId.Value.ToString();
        }
        else
        {
            editCategory.Sort = 99;
            parentId = "0";
        }

        var getCategorySelectListTask = GetCategorySelectListAsync();

        await Task.WhenAll(getCategorySelectListTask, Task.Delay(200));

        isShowEditCategory = true;

        StateHasChanged();
    }

    async Task SaveCategoryAsync()
    {
        saveLoading = true;
        try
        {
            if (parentId == "0")
            {
                editCategory.ParentId = null;
            }
            else
            {
                editCategory.ParentId = long.Parse(parentId);
            }

            if (categoryId == default)
            {
                using var httpResponse = await Http.PostAsJsonAsync<EditCategoryDto>("Article/CreateCategory", editCategory, JsonHelper.SerializeOpts);
                if (httpResponse.IsSuccessStatusCode)
                {
                    Message.Success("添加成功");
                    isShowEditCategory = false;
                    await GetCategoryListAsync();
                }
                else if ((int)httpResponse.StatusCode != 400)
                {
                    Message.Error("添加失败");
                }
            }
            else
            {
                using var httpResponse = await Http.PostAsJsonAsync<EditCategoryDto>("Article/UpdateCategory?categoryId=" + categoryId, editCategory, JsonHelper.SerializeOpts);

                if (httpResponse.IsSuccessStatusCode)
                {
                    Message.Success("编辑成功");
                    isShowEditCategory = false;
                    await GetCategoryListAsync();
                }
                else if ((int)httpResponse.StatusCode != 400)
                {
                    Message.Error("编辑失败");
                }
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
        finally
        {
            saveLoading = false;
            StateHasChanged();
        }
    }


    async Task DeleteCategoryAsync(long categoryId)
    {
        try
        {
            using var httpResponse = await Http.DeleteAsync("Article/DeleteCategory?id=" + categoryId);
            if (httpResponse.IsSuccessStatusCode)
            {
                await GetCategoryListAsync();
                Message.Success("删除成功");
            }
            else if ((int)httpResponse.StatusCode != 400)
            {
                Message.Error("删除失败");
            }
        }
        catch (HttpRequestException)
        {
            Message.Error("请求失败，请稍后重试");
        }
    }


    /// <summary>
    /// 获取当前页顶级栏目数量
    /// </summary>
    int RootCategoryCount()
    {
        return pageList.List?.Count(item => item.ParentId == null) ?? 0;
    }


    /// <summary>
    /// 获取父级栏目显示文本
    /// </summary>
    string ParentCategoryText(CategoryDto category)
    {
        return string.IsNullOrWhiteSpace(category.ParentName) ? "无父级栏目" : category.ParentName;
    }


    /// <summary>
    /// 获取备注显示文本
    /// </summary>
    string RemarkText(CategoryDto category)
    {
        return string.IsNullOrWhiteSpace(category.Remark) ? "暂无备注说明" : category.Remark;
    }


    /// <summary>
    /// 获取默认排序描述
    /// </summary>
    string SortBaselineText()
    {
        return "99 起";
    }


}
