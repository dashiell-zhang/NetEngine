@page "/operations/llmconversation"
@using Application.Model.LLM.LlmConversation
@using Common;
@using System.Net.Http.Json
@attribute [ReuseTabsPageTitle("LLM会话日志")]

<div class="llm-conversation-page">
    <div class="llm-conversation-page__hero">
        <div>
            <div class="llm-conversation-page__eyebrow">Operations</div>
            <h2 class="llm-conversation-page__title">LLM 会话日志</h2>
            <div class="llm-conversation-page__subtitle">按应用、时间范围和上下文关键字检索会话记录，快速回看 System、User 与 Assistant 内容，定位提示词与响应问题</div>
        </div>

        <div class="llm-conversation-page__stats">
            <div class="llm-conversation-page__stat-card">
                <span class="llm-conversation-page__stat-label">会话总量</span>
                <strong class="llm-conversation-page__stat-value">@pageList.Total</strong>
                <span class="llm-conversation-page__stat-foot">当前页展示 @(pageList.List?.Count ?? 0) 条记录</span>
            </div>

            <div class="llm-conversation-page__stat-card">
                <span class="llm-conversation-page__stat-label">时间筛选</span>
                <strong class="llm-conversation-page__stat-value llm-conversation-page__stat-value--small">@DateRangeText()</strong>
                <span class="llm-conversation-page__stat-foot">支持按起止时间回溯调用过程</span>
            </div>

            <div class="llm-conversation-page__stat-card">
                <span class="llm-conversation-page__stat-label">检索状态</span>
                <strong class="llm-conversation-page__stat-value llm-conversation-page__stat-value--small">@(string.IsNullOrWhiteSpace(request.Keyword) ? "全部会话" : "关键词检索")</strong>
                <span class="llm-conversation-page__stat-foot">第 @request.Page 页 / 每页 @request.PageSize 条</span>
            </div>
        </div>
    </div>

    <Card Class="llm-conversation-page__card llm-conversation-page__card--compact" BodyStyle="padding: 16px 18px">
        <Form Class="llm-conversation-page__filter-form" Model="@request" Layout="@FormLayout.Inline" OnFinish="HandleSearchAsync">
            <FormItem Class="llm-conversation-page__filter-item llm-conversation-page__filter-item--keyword">
                <Input @bind-Value="@context.Keyword" Placeholder="应用 Code / 名称 / System / User / Assistant 关键字" AllowClear />
            </FormItem>

            <FormItem Class="llm-conversation-page__filter-item llm-conversation-page__filter-item--time">
                <DatePicker @bind-Value="@context.StartTime" Format="yyyy-MM-dd HH:mm:ss" ShowTime="@true" Placeholder="@("请选择开始时间")" Style="width:100%" />
            </FormItem>

            <FormItem Class="llm-conversation-page__filter-item llm-conversation-page__filter-item--time">
                <DatePicker @bind-Value="@context.EndTime" Format="yyyy-MM-dd HH:mm:ss" ShowTime="@true" Placeholder="@("请选择结束时间")" Style="width:100%" />
            </FormItem>

            <FormItem Class="llm-conversation-page__filter-item llm-conversation-page__filter-item--actions">
                <div class="llm-conversation-page__filter-actions">
                    <Button Class="llm-conversation-page__action-button llm-conversation-page__action-button--primary" Type="@ButtonType.Primary" HtmlType="submit">搜索会话</Button>
                    <Button Class="llm-conversation-page__action-button llm-conversation-page__action-button--default" OnClick="HandleReset">重置条件</Button>
                </div>
            </FormItem>
        </Form>
    </Card>

    <Card Class="llm-conversation-page__card llm-conversation-page__card--compact" BodyStyle="padding: 14px 14px 10px">
        <div class="llm-conversation-page__list-shell">
            <div class="llm-conversation-page__table-wrap">
                <Table TItem="LlmConversationDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

                    <ColumnDefinitions>
                        <ActionColumn Title="应用">
                            <div class="llm-conversation-page__app-cell">
                                <div class="llm-conversation-page__app-name" title="@context.LlmAppName">@context.LlmAppName</div>
                            </div>
                        </ActionColumn>

                        <ActionColumn Title="System">
                            <div class="llm-conversation-page__preview-cell" title="@context.SystemContent">
                                @StringHelper.SubstringText(context.SystemContent, 60)
                            </div>
                        </ActionColumn>

                        <ActionColumn Title="User">
                            <div class="llm-conversation-page__preview-cell" title="@context.UserContent">
                                @StringHelper.SubstringText(context.UserContent, 60)
                            </div>
                        </ActionColumn>

                        <ActionColumn Title="Assistant">
                            <div class="llm-conversation-page__preview-cell" title="@context.AssistantContent">
                                @StringHelper.SubstringText(context.AssistantContent, 60)
                            </div>
                        </ActionColumn>

                        <PropertyColumn Property="c => c.CreateTime.LocalDateTime" Format="yyyy-MM-dd HH:mm" Title="时间"></PropertyColumn>

                        <ActionColumn Title="操作">
                            <Space>
                                <SpaceItem>
                                    <a class="llm-conversation-page__link" @onclick="() => ViewDetail(context)">查看详情</a>
                                </SpaceItem>
                            </Space>
                        </ActionColumn>
                    </ColumnDefinitions>

                    <PaginationTemplate>
                        <div class="llm-conversation-page__pagination">
                            <Pagination Total="@pageList.Total" PageSize="@request.PageSize" Current="@request.Page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
                        </div>
                    </PaginationTemplate>

                </Table>
            </div>
        </div>
    </Card>
</div>


<Drawer Closable="true" Width="1180" Visible="isShowDetail" Title='("LLM会话详情")' OnClose="() => isShowDetail = false">
    <Template style="height:100%">
        <div class="llm-conversation-drawer">
            <div class="llm-conversation-drawer__overview">
                <div class="llm-conversation-drawer__summary">
                    <div class="llm-conversation-drawer__summary-main">
                        <div class="llm-conversation-drawer__summary-eyebrow">Conversation</div>
                        <div class="llm-conversation-drawer__summary-title">@(string.IsNullOrWhiteSpace(detail?.LlmAppName) ? "未命名应用" : detail!.LlmAppName)</div>
                        <div class="llm-conversation-drawer__summary-subtitle">应用 Code：@(string.IsNullOrWhiteSpace(detail?.LlmAppCode) ? "-" : detail!.LlmAppCode)</div>
                    </div>

                    <div class="llm-conversation-drawer__summary-meta">
                        <span class="llm-conversation-drawer__meta-pill llm-conversation-drawer__meta-pill--time">@(detail == null ? "暂无时间" : detail.CreateTime.LocalDateTime.ToString("yyyy-MM-dd HH:mm"))</span>
                    </div>
                </div>

                <div class="llm-conversation-drawer__meta-grid">
                    <div class="llm-conversation-drawer__meta-item">
                        <span class="llm-conversation-drawer__meta-label">应用ID</span>
                        <span class="llm-conversation-drawer__meta-value llm-conversation-drawer__meta-value--mono">@(detail == null ? "-" : detail.LlmAppId.ToString())</span>
                    </div>

                    <div class="llm-conversation-drawer__meta-item">
                        <span class="llm-conversation-drawer__meta-label">创建人</span>
                        <span class="llm-conversation-drawer__meta-value">@(string.IsNullOrWhiteSpace(detail?.CreateUserName) ? "-" : detail!.CreateUserName)</span>
                    </div>

                    <div class="llm-conversation-drawer__meta-item">
                        <span class="llm-conversation-drawer__meta-label">创建人ID</span>
                        <span class="llm-conversation-drawer__meta-value llm-conversation-drawer__meta-value--mono">@(detail == null ? "-" : detail.CreateUserId.ToString())</span>
                    </div>

                    <div class="llm-conversation-drawer__meta-item llm-conversation-drawer__meta-item--wide">
                        <span class="llm-conversation-drawer__meta-label">会话ID</span>
                        <span class="llm-conversation-drawer__meta-value llm-conversation-drawer__meta-value--mono">@(detail == null ? "-" : detail.Id.ToString())</span>
                    </div>
                </div>
            </div>

            <div class="llm-conversation-drawer__content-grid">
                <div class="llm-conversation-drawer__content-box">
                    <div class="llm-conversation-drawer__content-toolbar">
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-caption">System</span>
                    </div>

                    <TextArea Value="@detailSystem" ReadOnly style="width:100%" />
                </div>

                <div class="llm-conversation-drawer__content-box">
                    <div class="llm-conversation-drawer__content-toolbar">
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-caption">User</span>
                    </div>

                    <TextArea Value="@detailUser" ReadOnly style="width:100%" />
                </div>

                <div class="llm-conversation-drawer__content-box llm-conversation-drawer__content-box--full">
                    <div class="llm-conversation-drawer__content-toolbar">
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-dot"></span>
                        <span class="llm-conversation-drawer__content-caption">Assistant</span>
                    </div>

                    <TextArea Value="@detailAssistant" ReadOnly style="width:100%" />
                </div>
            </div>
        </div>
    </Template>
</Drawer>

<style>
    .llm-conversation-page {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-bottom: 12px;
    }

    .llm-conversation-page__hero {
        display: grid;
        grid-template-columns: minmax(280px, 1.3fr) minmax(320px, 1fr);
        gap: 12px;
        padding: 16px 18px;
        border-radius: 22px;
        background:
            radial-gradient(circle at top right, rgba(59, 130, 246, 0.18), transparent 36%),
            radial-gradient(circle at bottom left, rgba(45, 212, 191, 0.14), transparent 32%),
            linear-gradient(135deg, #f8fcff 0%, #eef7ff 48%, #f4fffd 100%);
        color: #10233f;
        border: 1px solid #e9eef5;
        box-shadow: 0 16px 34px rgba(59, 83, 119, 0.10);
    }

    .llm-conversation-page__eyebrow {
        margin-bottom: 8px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #2563eb;
    }

    .llm-conversation-page__title {
        margin: 0;
        font-size: 26px;
        line-height: 1.15;
        color: #10233f;
    }

    .llm-conversation-page__subtitle {
        margin-top: 6px;
        max-width: 660px;
        font-size: 11px;
        line-height: 1.6;
        color: #526075;
    }

    .llm-conversation-page__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        align-self: stretch;
    }

    .llm-conversation-page__stat-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 4px;
        min-height: 86px;
        padding: 10px 12px;
        border-radius: 18px;
        border: 1px solid #e4edf7;
        background: rgba(255, 255, 255, 0.86);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

    .llm-conversation-page__stat-card:nth-child(1) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(239, 246, 255, 0.96) 100%);
    }

    .llm-conversation-page__stat-card:nth-child(2) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(236, 253, 245, 0.96) 100%);
    }

    .llm-conversation-page__stat-card:nth-child(3) {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(245, 243, 255, 0.96) 100%);
    }

    .llm-conversation-page__stat-label {
        font-size: 11px;
        color: #64748b;
    }

    .llm-conversation-page__stat-value {
        font-size: 20px;
        line-height: 1.2;
        color: #10233f;
    }

    .llm-conversation-page__stat-value--small {
        font-size: 16px;
    }

    .llm-conversation-page__stat-foot {
        font-size: 11px;
        line-height: 1.5;
        color: #64748b;
    }

    .llm-conversation-page__card {
        border-radius: 18px;
        border: 1px solid #edf2f7;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    }

    .llm-conversation-page__card--compact {
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.05);
    }

    .llm-conversation-page__filter-form,
    .llm-conversation-page__filter-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .llm-conversation-page__filter-form .ant-form-item {
        margin-right: 0;
        margin-bottom: 0;
    }

    .llm-conversation-page__filter-item--keyword {
        flex: 1 1 420px;
        min-width: 320px;
    }

    .llm-conversation-page__filter-item--time {
        flex: 0 0 240px;
    }

    .llm-conversation-page__filter-item--actions {
        margin-left: auto;
    }

    .llm-conversation-page__filter-form .ant-input,
    .llm-conversation-page__filter-form .ant-input-affix-wrapper,
    .llm-conversation-page__filter-form .ant-picker {
        height: 44px;
        width: 100%;
        border-radius: 16px;
        border-color: #dbe7f5;
        background: #ffffff;
        box-shadow: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .llm-conversation-page__filter-form .ant-input,
    .llm-conversation-page__filter-form .ant-input-affix-wrapper,
    .llm-conversation-page__filter-form .ant-picker {
        padding-left: 14px;
        padding-right: 14px;
    }

    .llm-conversation-page__filter-form .ant-input,
    .llm-conversation-page__filter-form .ant-input-affix-wrapper .ant-input,
    .llm-conversation-page__filter-form .ant-picker input {
        color: #334155;
        font-size: 13px;
    }

    .llm-conversation-page__filter-form .ant-input::placeholder,
    .llm-conversation-page__filter-form .ant-input-affix-wrapper .ant-input::placeholder,
    .llm-conversation-page__filter-form .ant-picker input::placeholder {
        color: #94a3b8;
    }

    .llm-conversation-page__filter-form .ant-input:hover,
    .llm-conversation-page__filter-form .ant-input-affix-wrapper:hover,
    .llm-conversation-page__filter-form .ant-picker:hover {
        border-color: #bfdbfe;
    }

    .llm-conversation-page__filter-form .ant-input:focus,
    .llm-conversation-page__filter-form .ant-input-focused,
    .llm-conversation-page__filter-form .ant-input-affix-wrapper-focused,
    .llm-conversation-page__filter-form .ant-picker-focused {
        border-color: #93c5fd;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.10);
    }

    .llm-conversation-page__action-button {
        height: 40px;
        padding: 0 18px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 600;
        box-shadow: none;
    }

    .llm-conversation-page__action-button--primary {
        border-color: #93c5fd;
        background: linear-gradient(180deg, #60a5fa 0%, #3b82f6 100%);
    }

    .llm-conversation-page__action-button--primary:hover,
    .llm-conversation-page__action-button--primary:focus {
        border-color: #60a5fa;
        background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
    }

    .llm-conversation-page__action-button--default {
        color: #334155;
        border-color: #dbe7f5;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .llm-conversation-page__action-button--default:hover,
    .llm-conversation-page__action-button--default:focus {
        color: #1d4ed8;
        border-color: #bfdbfe;
        background: linear-gradient(180deg, #fafdff 0%, #eff6ff 100%);
    }

    .llm-conversation-page__list-shell {
        border: 1px solid #e8eef6;
        border-radius: 18px;
        overflow: hidden;
        background: linear-gradient(180deg, #ffffff 0%, #fcfdff 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

    .llm-conversation-page__table-wrap {
        overflow: hidden;
        border-radius: 16px;
    }

    .llm-conversation-page__table-wrap .ant-table {
        background: transparent;
    }

    .llm-conversation-page__table-wrap .ant-table table {
        table-layout: fixed;
        width: 100%;
    }

    .llm-conversation-page__table-wrap .ant-table-thead > tr > th {
        padding: 14px 12px;
        background: linear-gradient(180deg, #fbfdff 0%, #f3f8ff 100%);
        color: #475569;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.04em;
        border-bottom: 1px solid #dbe7f5;
    }

    .llm-conversation-page__table-wrap .ant-table-thead > tr > th::before {
        display: none;
    }

    .llm-conversation-page__table-wrap .ant-table-tbody > tr > td {
        padding: 14px 12px;
        color: #1e293b;
        font-size: 13px;
        border-bottom: 1px solid #eef2f7;
        transition: background-color 0.2s ease;
    }

    .llm-conversation-page__table-wrap .ant-table-tbody > tr:hover > td {
        background: #f8fbff;
    }

    .llm-conversation-page__table-wrap .ant-table-tbody > tr:last-child > td {
        border-bottom: none;
    }

    .llm-conversation-page__table-wrap .ant-table-thead > tr > th:nth-child(1),
    .llm-conversation-page__table-wrap .ant-table-tbody > tr > td:nth-child(1) {
        width: 200px;
    }

    .llm-conversation-page__table-wrap .ant-table-thead > tr > th:nth-child(5),
    .llm-conversation-page__table-wrap .ant-table-tbody > tr > td:nth-child(5) {
        width: 160px;
        white-space: nowrap;
    }

    .llm-conversation-page__table-wrap .ant-table-thead > tr > th:nth-child(6),
    .llm-conversation-page__table-wrap .ant-table-tbody > tr > td:nth-child(6) {
        width: 140px;
        white-space: nowrap;
    }

    .llm-conversation-page__app-cell {
        display: block;
        min-width: 0;
        max-width: 100%;
    }

    .llm-conversation-page__app-name {
        color: #334155;
        font-weight: 600;
        font-size: 13px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .llm-conversation-page__preview-cell {
        width: 100%;
        max-width: 100%;
        color: #475569;
        font-size: 13px;
        line-height: 1.6;
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
        display: block;
    }

    .llm-conversation-page__link {
        color: #1d4ed8;
        font-weight: 600;
    }

    .llm-conversation-page__pagination {
        margin: 0;
        display: flex;
        justify-content: flex-end;
        padding: 14px 16px 16px 16px;
        border-top: 1px solid #eef4fb;
        background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
    }

    .llm-conversation-page__pagination .ant-pagination-total-text {
        color: #64748b;
        font-size: 12px;
    }

    .llm-conversation-page__pagination .ant-pagination-item,
    .llm-conversation-page__pagination .ant-pagination-prev .ant-pagination-item-link,
    .llm-conversation-page__pagination .ant-pagination-next .ant-pagination-item-link,
    .llm-conversation-page__pagination .ant-pagination-options-size-changer.ant-select .ant-select-selector,
    .llm-conversation-page__pagination .ant-pagination-options-quick-jumper input {
        border-radius: 10px;
        border-color: #dbe7f5;
        box-shadow: none;
    }

    .llm-conversation-page__pagination .ant-pagination-item-active {
        background: linear-gradient(180deg, #eef6ff 0%, #dbeafe 100%);
        border-color: #93c5fd;
    }

    .llm-conversation-page__pagination .ant-pagination-item-active a {
        color: #1d4ed8;
        font-weight: 700;
    }

    .llm-conversation-drawer {
        display: flex;
        flex-direction: column;
        gap: 14px;
        min-height: calc(100vh - 180px);
    }

    .llm-conversation-drawer__overview {
        padding: 18px;
        border-radius: 18px;
        border: 1px solid #e6eef8;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

    .llm-conversation-drawer__summary {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        padding: 4px 2px 16px 2px;
        border-bottom: 1px solid #eef4fb;
    }

    .llm-conversation-drawer__summary-eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #2563eb;
        margin-bottom: 8px;
    }

    .llm-conversation-drawer__summary-title {
        font-size: 22px;
        font-weight: 700;
        color: #10233f;
    }

    .llm-conversation-drawer__summary-subtitle {
        margin-top: 6px;
        color: #526075;
        font-size: 13px;
        line-height: 1.7;
        word-break: break-all;
    }

    .llm-conversation-drawer__summary-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
    }

    .llm-conversation-drawer__meta-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        line-height: 1;
        white-space: nowrap;
    }

    .llm-conversation-drawer__meta-pill--time {
        color: #526075;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid #dbe7f5;
    }

    .llm-conversation-drawer__meta-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin-top: 14px;
    }

    .llm-conversation-drawer__meta-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-height: 78px;
        padding: 14px 16px;
        border-radius: 14px;
        background: linear-gradient(180deg, #fdfefe 0%, #f8fbff 100%);
        border: 1px solid #eaf1f8;
    }

    .llm-conversation-drawer__meta-item--wide {
        grid-column: span 3;
    }

