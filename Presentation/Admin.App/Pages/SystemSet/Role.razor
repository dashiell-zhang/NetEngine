@page "/systemset/role"
@using Application.Model.User.Role
@attribute [ReuseTabsPageTitle("角色管理")]

<div class="system-role-page">
    <div class="system-role-page__hero admin-page-hero--with-actions">
        <div>
            <div class="system-role-page__eyebrow">System Settings</div>
            <h2 class="system-role-page__title">角色管理工作台</h2>
            <div class="system-role-page__subtitle">集中维护角色编码、角色说明与权限范围，让角色创建、维护和授权配置都在一个页面内完成</div>

            @if (functionList.Contains("role-add"))
            {
                <div class="system-role-page__hero-tools">
                    <Button Class="system-role-page__action-button system-role-page__action-button--primary admin-page-button admin-page-button--primary admin-page-button--with-plus" Type="@ButtonType.Primary" @onclick="() => EditRole()"><span class="admin-page-button__content"><span class="admin-page-button__icon" aria-hidden="true">+</span><span class="admin-page-button__text">新增角色</span><span class="admin-page-button__spacer" aria-hidden="true"></span></span></Button>
                </div>
            }
        </div>

        <div class="system-role-page__stats">
            <div class="system-role-page__stat-card">
                <span class="system-role-page__stat-label">角色总量</span>
                <strong class="system-role-page__stat-value">@pageList.Total</strong>
                <span class="system-role-page__stat-foot">当前页展示 @(pageList.List?.Count ?? 0) 个角色</span>
            </div>

            <div class="system-role-page__stat-card">
                <span class="system-role-page__stat-label">操作能力</span>
                <strong class="system-role-page__stat-value system-role-page__stat-value--small">@OperationCapabilityText()</strong>
                <span class="system-role-page__stat-foot">支持编辑、删除和权限配置等操作</span>
            </div>

            <div class="system-role-page__stat-card">
                <span class="system-role-page__stat-label">分页状态</span>
                <strong class="system-role-page__stat-value system-role-page__stat-value--small">第 @(page) 页</strong>
                <span class="system-role-page__stat-foot">每页 @(pageSize) 条</span>
            </div>
        </div>
    </div>

    <Card Class="system-role-page__card system-role-page__card--compact" BodyStyle="padding: 14px 14px 10px">
        <div class="system-role-page__list-shell admin-page-list-shell">
            <div class="system-role-page__table-wrap">
                <Table TItem="RoleDto" DataSource="@pageList.List" Total="@pageList.Total" Loading="tableLoading" RemoteDataSource>

                    <ColumnDefinitions>
                        <ActionColumn Title="角色">
                            <div class="system-role-page__role-cell">
                                <div class="system-role-page__role-name" title="@context.Name">@context.Name</div>
                                <div class="system-role-page__role-sub" title="@context.Code">@context.Code</div>
                            </div>
                        </ActionColumn>

                        <ActionColumn Title="说明">
                            <div class="system-role-page__remark-cell" title="@(string.IsNullOrWhiteSpace(context.Remark) ? "暂无备注说明" : context.Remark)">@(string.IsNullOrWhiteSpace(context.Remark) ? "暂无备注说明" : context.Remark)</div>
                        </ActionColumn>

                        <ActionColumn Title="创建时间">
                            <div class="system-role-page__time-cell">@context.CreateTime.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                        </ActionColumn>

                        <ActionColumn Title="操作">
                            <Space>
                                @if (functionList.Contains("role-edit"))
                                {
                                    <SpaceItem>
                                        <a class="system-role-page__link" @onclick="() => EditRole(context)">编辑</a>
                                    </SpaceItem>
                                }

                                @if (functionList.Contains("role-function"))
                                {
                                    <SpaceItem>
                                        <a class="system-role-page__link system-role-page__link--accent" @onclick="() => EditAuthorityAsync(context)">权限范围</a>
                                    </SpaceItem>
                                }

                                @if (functionList.Contains("role-delete"))
                                {
                                    <SpaceItem>
                                        <Popconfirm Title="确认要删除吗？"
                                                    OnConfirm="_ => DeleteRoleAsync(context.Id)"
                                                    OkText="Yes"
                                                    CancelText="No">
                                            <a class="system-role-page__link system-role-page__link--danger">删除</a>
                                        </Popconfirm>
                                    </SpaceItem>
                                }
                            </Space>
                        </ActionColumn>
                    </ColumnDefinitions>

                    <PaginationTemplate>
                        <div class="system-role-page__pagination admin-page-list-pagination">
                            <Pagination Total="@pageList.Total" PageSize="pageSize" Current="page" ShowSizeChanger OnChange="PageChange" ShowQuickJumper ShowTotal="showTotal" />
                        </div>
                    </PaginationTemplate>

                </Table>
            </div>
        </div>
    </Card>
</div>


<Drawer Closable="true" Width="700" Visible="isShowEditRole" Title='(roleId == default ? "新增角色" : "编辑角色")' OnClose="() => isShowEditRole = false">
    <Template style="height:100%">
        <div class="system-role-drawer">
            <Form Class="system-role-drawer__form" Model="@editRole" Layout="@FormLayout.Vertical" OnFinish="SaveRoleAsync">
                <div class="system-role-drawer__section">
                    <div class="system-role-drawer__section-title">基础资料</div>

                    <Row Gutter="24">
                        <AntDesign.Col Span="12">
                            <FormItem Class="system-role-drawer__field-item">
                                <div class="system-role-drawer__field-label admin-required-label">编码</div>
                                <Input Placeholder="请输入编码" @bind-Value="@context.Code" />
                            </FormItem>
                        </AntDesign.Col>

                        <AntDesign.Col Span="12">
                            <FormItem Class="system-role-drawer__field-item">
                                <div class="system-role-drawer__field-label admin-required-label">名称</div>
                                <Input Placeholder="请输入名称" @bind-Value="@context.Name" />
                            </FormItem>
                        </AntDesign.Col>
                    </Row>

                    <FormItem Class="system-role-drawer__field-item">
                        <div class="system-role-drawer__field-label">备注</div>
                        <TextArea Placeholder="请输入备注" @bind-Value="@context.Remark" MinRows="4" MaxRows="6" style="width:100%" />
                    </FormItem>
                </div>

                <div class="system-role-drawer__footer">
                    <Button Class="system-role-page__action-button system-role-page__action-button--primary admin-page-button admin-page-button--primary" Type="@ButtonType.Primary" HtmlType="submit" Loading="@saveLoading">保存角色</Button>
                    <Button Class="system-role-page__action-button system-role-page__action-button--default admin-page-button admin-page-button--default" Type="@ButtonType.Default" @onclick="() => isShowEditRole = false">取消</Button>
                </div>
            </Form>
        </div>
    </Template>
</Drawer>


<Modal Title="权限范围" Style="width:1160px;" Visible="@isShowEditAuthority" OnCancel="() => isShowEditAuthority = false" Footer="null" MaxBodyHeight="@("70vh")">
    <div class="system-role-authority">
        <div class="system-role-authority__overview">
            <div>
                <div class="system-role-authority__eyebrow">Authority Scope</div>
                <div class="system-role-authority__title">@AuthorityRoleText()</div>
                <div class="system-role-authority__subtitle">按菜单模块和功能操作逐项勾选，保存结果会立即同步到当前角色的权限范围</div>
            </div>

            <div class="system-role-authority__meta-pill">已加载 @roleFunctionList.Count 个顶层模块</div>
        </div>

        <div class="system-role-authority__table-wrap">
            <Table TItem="RoleFunctionDto" DataSource="roleFunctionList" TreeChildren="item => item.ChildList" DefaultExpandAllRows HidePagination>

                <Column Title="菜单模块" TData="string">
                    <div class="system-role-authority__menu-cell">
                        <Checkbox Label="@context.Id.ToString()" @bind-Value="context.IsCheck" OnChange="isCheck => SetRoleFunctionAsync(isCheck, context)">@context.Name</Checkbox>
                    </div>
                </Column>

                <Column Title="功能操作" TData="string">
                    <div class="system-role-authority__action-grid">
                        @if (context.FunctionList == null || context.FunctionList.Count == 0)
                        {
                            <span class="system-role-authority__empty">当前模块暂无独立功能项</span>
                        }
                        else
                        {
                            @foreach (var item in context.FunctionList)
                            {
                                <label class="system-role-authority__action-pill">
                                    <Checkbox Label="@item.Id.ToString()" @bind-Value="item.IsCheck" OnChange="isCheck => SetRoleFunctionAsync(isCheck, item)">@item.Name</Checkbox>
                                </label>
                            }
                        }
                    </div>
                </Column>

            </Table>
        </div>
    </div>
</Modal>


